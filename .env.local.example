# Cloud AssetLibrary: Supabase Storage source + PostgreSQL metadata + MinIO objects.
# Copy scripts/docker/asset-library values into .env.local, then start with the documented compose command.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_ALLOW_EXTERNAL=false
DEEPSEEK_API_KEY=
GAMECASTLE_STORAGE_POSTGRES_IMAGE=pgvector/pgvector:pg15
GAMECASTLE_STORAGE_MINIO_IMAGE=minio/minio
GAMECASTLE_STORAGE_MC_IMAGE=minio/mc
GAMECASTLE_STORAGE_IMAGE=ghcr.io/supabase/storage-api@sha256:a3c9d39fb965b6840225fea33b24b977342eae42c49bbbe02034df3e0aa7d101
GAMECASTLE_STORAGE_POSTGRES_DB=postgres
GAMECASTLE_STORAGE_POSTGRES_USER=postgres
GAMECASTLE_STORAGE_POSTGRES_PASSWORD=replace-with-a-local-secret
GAMECASTLE_STORAGE_BACKEND_BUCKET=gamecastle-storage-backend
GAMECASTLE_STORAGE_JWT_SECRET=
GAMECASTLE_ASSET_LIBRARY_SERVICE_KEY=
GAMECASTLE_ASSET_LIBRARY_URL=http://127.0.0.1:5000
GAMECASTLE_ASSET_LIBRARY_BUCKET=gamecastle-assets
GAMECASTLE_ASSET_LIBRARY_PORT=5000
GAMECASTLE_S3_PORT=9000
GAMECASTLE_S3_CONSOLE_PORT=9001
GAMECASTLE_S3_REGION=us-east-1
GAMECASTLE_S3_ACCESS_KEY=gamecastle
GAMECASTLE_S3_SECRET_KEY=replace-with-a-local-secret
COMFYUI_ENDPOINT=http://127.0.0.1:8188
COMFYUI_ALLOW_LOCAL=true
ASSET_MODEL_PROVIDER=comfyui-local
ASSET_IMAGE_MODEL=gamecastle.master-image.sdxl-base-refiner.v1
# ComfyUI owns only the pinned core-node SDXL base-to-refiner master-image workflow.
# Deterministic background removal, sizing, anchors, and FrameSet frames run locally.
COMFYUI_MODEL_PATH=../ComfyUI_windows_portable/ComfyUI/models/checkpoints/sd_xl_base_1.0.safetensors
COMFYUI_MODEL_SHA256=
COMFYUI_REFINER_PATH=../ComfyUI_windows_portable/ComfyUI/models/checkpoints/sd_xl_refiner_1.0.safetensors
COMFYUI_REFINER_SHA256=
COMFYUI_POLL_MS=250

# Spatial planning is opt-in and requires a configured vision-capable provider.
SPATIAL_MODEL_PROVIDER=
SPATIAL_VISION_MODEL=
SPATIAL_MODEL_MAX_COST=
SPATIAL_ALLOW_EXTERNAL=false
