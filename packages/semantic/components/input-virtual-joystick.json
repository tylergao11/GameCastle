{
  "schemaVersion": 3,
  "id": "input.virtual_joystick",
  "kind": "control",
  "name": "Virtual Joystick",
  "summary": "A mobile direction control that drives a character with top-down movement.",
  "extends": ["input.touch_surface"],
  "target": { "required": true, "roles": ["player", "character"] },
  "config": {
    "direction": { "type": "enum", "values": ["horizontal", "vertical", "omnidirectional"], "default": "omnidirectional", "summary": "Directions accepted by the control." },
    "placement": { "type": "layout-choice", "values": ["gc-layout://screen/control-bottom-left", "gc-layout://screen/control-bottom-right"], "default": "gc-layout://screen/control-bottom-left", "summary": "Safe screen anchor for the centered control." },
    "size": { "type": "number", "minimum": 1, "maximum": 128, "default": 96, "summary": "Visible control diameter or side length in screen pixels." }
  },
  "bindings": {},
  "implementation": {
    "targetMembers": [],
    "targetBehaviors": ["topdown"],
    "entities": [],
    "layouts": [],
    "events": [
      { "name": "left", "kind": "rule", "whenConfigIn": { "name": "direction", "values": ["horizontal", "omnidirectional"] }, "conditions": [{ "use": "input.pointer.held", "arguments": { "button": "Left" } }, { "use": "input.pointer.on-object", "arguments": { "target": "$surface" } }, { "use": "input.pointer.x.compare-object", "arguments": { "operator": "<", "target": "$surface" } }], "actions": [{ "use": "movement.topdown.left", "arguments": { "target": "$target" } }] },
      { "name": "right", "kind": "rule", "whenConfigIn": { "name": "direction", "values": ["horizontal", "omnidirectional"] }, "conditions": [{ "use": "input.pointer.held", "arguments": { "button": "Left" } }, { "use": "input.pointer.on-object", "arguments": { "target": "$surface" } }, { "use": "input.pointer.x.compare-object", "arguments": { "operator": ">", "target": "$surface" } }], "actions": [{ "use": "movement.topdown.right", "arguments": { "target": "$target" } }] },
      { "name": "up", "kind": "rule", "whenConfigIn": { "name": "direction", "values": ["vertical", "omnidirectional"] }, "conditions": [{ "use": "input.pointer.held", "arguments": { "button": "Left" } }, { "use": "input.pointer.on-object", "arguments": { "target": "$surface" } }, { "use": "input.pointer.y.compare-object", "arguments": { "operator": "<", "target": "$surface" } }], "actions": [{ "use": "movement.topdown.up", "arguments": { "target": "$target" } }] },
      { "name": "down", "kind": "rule", "whenConfigIn": { "name": "direction", "values": ["vertical", "omnidirectional"] }, "conditions": [{ "use": "input.pointer.held", "arguments": { "button": "Left" } }, { "use": "input.pointer.on-object", "arguments": { "target": "$surface" } }, { "use": "input.pointer.y.compare-object", "arguments": { "operator": ">", "target": "$surface" } }], "actions": [{ "use": "movement.topdown.down", "arguments": { "target": "$target" } }] }
    ]
  }
}
