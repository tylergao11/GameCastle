{
  "schemaVersion": 1,
  "id": "network.p2p-lockstep",
  "category": "network",
  "version": 1,
  "summary": "Friend-session lockstep: deterministic input intents at playable cadence (default 60 Hz, min 30 Hz). Host is the room initiator; peers simulate locally.",
  "llm1Card": "Friends join the initiator's room. Everyone runs the same game logic from the same ordered inputs so the session stays in sync. Best for lightweight friend invite multiplayer, not ranked competitive server authority.",
  "provides": {
    "syncModels": [
      "lockstep-input"
    ],
    "topology": [
      "peer-to-peer",
      "star"
    ],
    "players": {
      "min": 2,
      "max": 8
    },
    "authority": [
      "host"
    ]
  },
  "requires": {
    "gameplay": {
      "deterministic": true,
      "fixedTimestep": true,
      "seededRNG": true,
      "declaredInputs": true
    },
    "serverSide": [
      "signaling-broker"
    ]
  },
  "dataFlow": {
    "control": {
      "channel": "control",
      "reliability": "reliable",
      "ordering": "ordered"
    },
    "input": {
      "channel": "input",
      "reliability": "reliable-or-redundant",
      "ordering": "tick-ordered"
    }
  },
  "transport": {
    "control": {
      "protocol": "websocket"
    },
    "input": {
      "protocol": "webrtc-datachannel",
      "mode": "unordered",
      "recovery": "tick-sequence-redundancy"
    }
  },
  "codec": {
    "control": {
      "format": "json"
    },
    "input": {
      "format": "protobuf"
    }
  },
  "syncConfig": {
    "tickRate": {
      "default": 60,
      "min": 30,
      "max": 60
    },
    "inputDelay": 2,
    "localPrediction": "required",
    "hostDisconnect": "dissolve-room"
  },
  "compiler": {
    "strategies": [
      "strategies/lockstep-input.js"
    ],
    "transports": [
      "transports/websocket.js",
      "transports/webrtc-unordered.js"
    ],
    "codecs": [
      "codecs/json.js",
      "codecs/protobuf.js"
    ],
    "protos": [
      "proto/lockstep-input.proto"
    ],
    "targetPlan": [
      "install network sync=lockstep-input authority=host tickRate={{tickRate}}",
      "set topology type=star-or-p2p maxPeers=8 host=initiator",
      "set determinism seedFrom=room random=seeded timestep=fixed",
      "set channel=control reliability=reliable ordering=ordered transport=websocket codec=json",
      "set channel=input reliability=reliable-or-redundant ordering=tick-ordered transport=webrtc codec=protobuf",
      "set recovery=input strategy=tick-sequence-redundancy includePreviousTicks=5 ack=true",
      "set inputDelay={{inputDelay}}",
      "set localPrediction=required",
      "set hostDisconnect=dissolve-room",
      "sync input {{inputs}} channel=input"
    ]
  }
}
