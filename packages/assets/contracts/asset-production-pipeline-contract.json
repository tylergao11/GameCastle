{
  "schemaVersion": 7,
  "contractId": "gamecastle.semantic-asset-production",
  "owner": "AssetProductionPipeline",
  "truthSources": {
    "self": "packages/assets/contracts/asset-production-pipeline-contract.json",
    "assetStyles": "packages/assets/contracts/asset-style-dictionary.json",
    "semanticSource": "packages/semantic/src/game-semantic-source.js",
    "derivation": "packages/assets/src/asset-derivation-pipeline.js"
  },
  "principles": [
    "GameSemanticSource owns semantic asset intent",
    "AssetLibrary may satisfy an exact requirement before generation",
    "ComfyUI creates a multi-candidate SDXL batch whose latent denoising is split between the official base and refiner models",
    "AssetDerivationPipeline deterministically creates static assets and FrameSet revisions",
    "CLIPImageReviewer must accept the final derived pixels before ledger, GDJS, or outbox",
    "StyleCohesion evaluates production-set palette structure and pairwise family cohesion after required slot coverage",
    "Later image work items inherit Style DNA generation prompts anchored to the first accepted image style session",
    "GDJS binds only accepted project-local revisions",
    "accepted new revisions enter the asynchronous publication outbox"
  ],
  "productionFamilies": {
    "character": { "defaultRecipeId": "character-sprite.v1" },
    "character-part": { "defaultRecipeId": "character-part-sprite.v1" },
    "world-geometry": { "defaultRecipeId": "world-tile.v1" },
    "prop": { "defaultRecipeId": "prop-sprite.v1" },
    "background": { "defaultRecipeId": "scene-background.v1" },
    "ui": { "defaultRecipeId": "ui-element.v1" },
    "effect": { "defaultRecipeId": "effect-sprite.v1" },
    "character-animation": { "defaultRecipeId": "character-frame-set.v1" },
    "effect-animation": { "defaultRecipeId": "effect-frame-set.v1" }
  },
  "retryPolicies": {
    "review-guided-generation.v1": {
      "generationAttempts": 3,
      "retryableCodes": ["MASTER_IMAGE_QUALITY_REJECTED", "ASSET_FINAL_REVIEW_REJECTED"]
    }
  },
  "recipes": {
    "character-sprite.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "character-part-sprite.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "world-tile.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "prop-sprite.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "scene-background.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "ui-element.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "effect-sprite.v1": { "artifactKind": "single-resource", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "semantic-review", "accept"] },
    "character-frame-set.v1": { "artifactKind": "frame-set", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "deterministic-frame-set", "semantic-review", "accept"] },
    "effect-frame-set.v1": { "artifactKind": "frame-set", "retryPolicyId": "review-guided-generation.v1", "minimumPath": ["master-image", "deterministic-static", "deterministic-frame-set", "semantic-review", "accept"] }
  },
  "artifacts": {
    "AssetProductionRequest": { "required": ["requestId", "projectId", "sourceHash", "requirements"] },
    "AssetProductionSetPlan": { "required": ["productionSetId", "sourceHash", "workItems", "dependencyGraph", "coveragePolicy", "contentHash"] },
    "AssetWorkItemPlan": { "required": ["workItemPlanId", "semanticId", "slotId", "targetVisualSlotId", "productionFamily", "recipeId", "artifactKind", "assetSpec", "stageSequence"] },
    "MasterImageRevision": { "required": ["revisionId", "path", "sha256", "width", "height", "providerReceipt"] },
    "SemanticReviewReceipt": { "required": ["receiptId", "phase", "workItemPlanId", "targetVisualSlotId", "reviewPolicyFingerprint", "modelRevision", "modelFingerprint", "imageSha256s", "semanticMargin", "styleMargin", "decisions", "decision"] },
    "WorkItemAcceptanceReceipt": { "required": ["workItemPlanId", "finalRevisionId", "targetVisualSlotId", "deterministicEvidenceIds", "reviewReceiptId", "styleId", "decision"] },
    "AssetProductionSetAcceptanceReceipt": { "required": ["productionSetId", "workItemAcceptanceReceiptIds", "requiredSlotCoverage", "acceptedRevisionByTargetVisualSlotId", "decision"] },
    "StyleCohesionReceipt": { "required": ["receiptId", "owner", "decision", "styleId", "styleFingerprint", "structure", "pairwise"] }
  }
}
