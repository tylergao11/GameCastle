{
  "schemaVersion": 3,
  "contractId": "gamecastle.asset-library",
  "owner": "AssetLibrary",
  "backend": {
    "kind": "supabase-storage",
    "upstream": {
      "repository": "https://github.com/supabase/storage",
      "commit": "afcfbfdd507a00f52abfab35074772a6fd2b9c18",
      "license": "Apache-2.0"
    },
    "client": {
      "package": "@supabase/storage-js",
      "version": "2.110.5",
      "repository": "https://github.com/supabase/supabase-js",
      "license": "MIT"
    },
    "environment": ["GAMECASTLE_ASSET_LIBRARY_URL", "GAMECASTLE_ASSET_LIBRARY_SERVICE_KEY", "GAMECASTLE_ASSET_LIBRARY_BUCKET"],
    "objectLayout": {
      "recordPrefix": "asset-library/v3/records",
      "blobPrefix": "asset-library/v3/blobs",
      "recordIdPrefix": "gamecastle.asset-library.record.v3"
    }
  },
  "principles": [
    "accepted revisions are the only publishable library content",
    "library lookup is deterministic from a complete asset requirement and the exact current Style DNA content",
    "library records are immutable and content-addressed",
    "the library accelerates creation but never decides semantic intent",
    "project materialization always verifies the published revision hash",
    "lookup and materialization failures fall through to local creation",
    "publication runs from a durable outbox after local acceptance",
    "publication failure never invalidates a locally accepted revision"
  ],
  "lifecycle": ["accepted", "publication-pending", "published"],
  "accumulation": {
    "outbox": {
      "documentKind": "asset-publication-outbox",
      "relativePath": ".gamecastle/asset-publication-outbox.json",
      "states": ["pending", "published"],
      "identity": ["requirementFingerprint", "revisionId"]
    },
    "failurePolicy": "keep-pending-with-failure-fact"
  },
  "operations": {
    "lookup": {
      "input": ["requirementFingerprint", "resourceKind", "acceptedFormats"],
      "output": ["recordId", "requirementFingerprint", "revision"]
    },
    "materialize": {
      "input": ["recordId", "revisionId", "projectId", "targetDirectory"],
      "output": ["revisionId", "sha256", "resourceKind", "format", "single-resource path or FrameSetRevision frame paths"]
    },
    "publish": {
      "input": ["requirementFingerprint", "revision", "provenance"],
      "output": ["recordId", "revisionId", "published"]
    }
  },
  "record": {
    "required": ["recordId", "requirementFingerprint", "revision", "status"],
    "singleResourceRevisionRequired": ["revisionId", "sha256", "resourceKind", "format"],
    "frameSetRevisionRequired": ["revisionId", "contentHash", "resourceKind", "format"],
    "revisionVariants": ["single-resource", "FrameSetRevision"],
    "frameSetRevision": "packages/assets/contracts/frame-set-contract.json"
  }
}
