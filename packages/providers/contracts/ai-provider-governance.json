{
  "schemaVersion": 1,
  "governanceId": "gamecastle.ai-provider-governance",
  "principles": ["keys-are-environment-only", "director-and-semantic-use-open-source-text-models", "modality-adapters-own-request-shapes", "external-calls-require-explicit-authorization", "usage-and-cost-are-receipted", "provider-runtime-is-the-only-external-invocation-path", "model-semantic-protocols-are-dsl-only"],
  "defaultProvider": "ollama",
  "providers": {
    "deepseek": { "endpointEnv": "LLM_ENDPOINT", "apiKeyEnv": "DEEPSEEK_API_KEY", "defaultEndpoint": "https://api.deepseek.com/v1", "textModelEnv": "LLM_MODEL", "defaultTextModel": "deepseek-v4-flash", "modalities": ["text"], "cachePolicy": { "commonPrefixWarmupRequests": 2 } },
    "openai": { "endpointEnv": "OPENAI_ENDPOINT", "apiKeyEnv": "OPENAI_API_KEY", "defaultEndpoint": "https://api.openai.com/v1", "textModelEnv": "OPENAI_TEXT_MODEL", "defaultTextModel": "gpt-4.1-mini", "imageModelEnv": "OPENAI_IMAGE_MODEL", "visionModelEnv": "OPENAI_VISION_MODEL", "modalities": ["text", "image-generation", "vision-review"], "cachePolicy": { "commonPrefixWarmupRequests": 1 } },
    "ollama": { "endpointEnv": "OLLAMA_ENDPOINT", "defaultEndpoint": "http://127.0.0.1:11434/v1", "defaultApiKey": "ollama", "textModelEnv": "OLLAMA_TEXT_MODEL", "defaultTextModel": "qwen3:8b", "visionModelEnv": "OLLAMA_VISION_MODEL", "defaultVisionModel": "qwen3-vl:8b", "requiresApiKey": false, "localOnly": true, "localAllowedEnv": "OLLAMA_ALLOW_LOCAL", "openSource": true, "modalities": ["text", "vision-review"], "cachePolicy": { "commonPrefixWarmupRequests": 1 } },
    "comfyui-local": { "endpointEnv": "COMFYUI_ENDPOINT", "defaultEndpoint": "", "textModelEnv": "COMFYUI_TEXT_MODEL", "defaultTextModel": "", "imageModelEnv": "COMFYUI_IMAGE_MODEL", "defaultImageModel": "gamecastle.master-image.sdxl-base-refiner.v1", "requiresApiKey": false, "localOnly": true, "modalities": ["image-generation"] },
    "simulated-local": { "defaultEndpoint": "local://simulated", "defaultTextModel": "simulated-text", "openSource": true, "modalities": ["text", "image-generation", "vision-review"], "cachePolicy": { "commonPrefixWarmupRequests": 1 } }
  },
  "assetDefaults": { "providerEnv": "ASSET_MODEL_PROVIDER", "imageModelEnv": "ASSET_IMAGE_MODEL", "visionModelEnv": "ASSET_VISION_MODEL", "maxCostEnv": "ASSET_MODEL_MAX_COST", "allowExternalEnv": "ASSET_ALLOW_EXTERNAL" },
  "spatialDefaults": { "providerEnv": "SPATIAL_MODEL_PROVIDER", "visionModelEnv": "SPATIAL_VISION_MODEL", "maxCostEnv": "SPATIAL_MODEL_MAX_COST", "allowExternalEnv": "SPATIAL_ALLOW_EXTERNAL" },
  "runtimeDefaults": { "allowExternalEnvs": ["AI_ALLOW_EXTERNAL", "LLM_ALLOW_EXTERNAL", "ASSET_ALLOW_EXTERNAL"], "timeoutMs": 30000, "maxAttempts": 3, "receiptPolicy": "safe-immutable" }
}
