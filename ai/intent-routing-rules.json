{
  "schemaVersion": 1,
  "intentSurface": {
    "canonicalStyle": "natural-game-intent",
    "allowedConcepts": [
      "thing",
      "component",
      "relation",
      "placement",
      "edit",
      "value",
      "role",
      "action"
    ],
    "prohibitedSurfacePatterns": [
      {
        "id": "coordinates",
        "description": "LLM2-facing intent must not ask for exact x/y placement or numeric movement deltas.",
        "examples": ["place at x y", "x=120 y=480", "move Fox up 10 pixels", "把狐狸往上10像素"]
      },
      {
        "id": "event-index",
        "description": "LLM2-facing intent must not select generated event indexes.",
        "examples": ["event index 4", "remove event #2"]
      },
      {
        "id": "gdjs-instruction",
        "description": "LLM2-facing intent must not name GDJS instructions.",
        "examples": ["CollisionNP", "MettreXY", "TextObject::String"]
      },
      {
        "id": "module-id",
        "description": "LLM2-facing intent must not require product module ids.",
        "examples": ["install module id=core.platformer"]
      },
      {
        "id": "component-id",
        "description": "LLM2-facing intent must not require component ids.",
        "examples": ["add component id=input.jump_button"]
      },
      {
        "id": "runtime-adapter",
        "description": "LLM2-facing intent must not name runtime adapters.",
        "examples": ["use runtime adapter gdjs.virtual_joystick"]
      },
      {
        "id": "key-value-machine-fields",
        "description": "LLM2-facing intent must not depend on key=value machine fields.",
        "examples": ["near=screen direction=bottom-right"]
      }
    ]
  },
  "admissionRule": {
    "allRequired": [
      "The concept names a reusable game-world concept that non-developers naturally understand.",
      "The concept cannot be expressed with existing thing/component/relation/placement/edit/value/role/action concepts.",
      "The concept is not merely a GDJS limitation, event shape, object field, runtime adapter option, coordinate rule, or generated-code workaround.",
      "The concept can compile through a deterministic owner with a ResultCard trace."
    ]
  },
  "routingOwners": [
    "intent-compiler",
    "symbol-rewrite",
    "inheritance-defaults",
    "component-manifest",
    "component-expander",
    "placement-resolver",
    "binding-compiler",
    "gdjs-bridge",
    "runtime-adapter",
    "runtime-executor",
    "gdevelop-truth",
    "component-catalog"
  ],
  "bridgeIssueRoutes": [
    {
      "id": "touch-multitouch-state",
      "problem": "Touch controls require multi-touch state that is awkward as GDJS events.",
      "routeOwner": "runtime-adapter",
      "routeMechanism": "bridge-target-rewrite",
      "prohibitedDslExpansions": ["on touch button pointerId=..."],
      "resultCardEvidence": ["rewrites", "runtimeAdapters", "ownerTrace"]
    },
    {
      "id": "joystick-dead-zone",
      "problem": "Joystick needs dead zone, radius, clamp, and axis smoothing.",
      "routeOwner": "component-manifest",
      "routeMechanism": "inheritance-defaults",
      "prohibitedDslExpansions": ["deadZone=0.15", "adapter clamp axis"],
      "resultCardEvidence": ["resolved", "autoAdded", "ownerTrace"]
    },
    {
      "id": "responsive-ui",
      "problem": "A UI control should work across screen sizes and safe areas.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "placement-contract",
      "prohibitedDslExpansions": ["place at x y", "screenWidth minus 96"],
      "resultCardEvidence": ["placementResolutions", "resolved", "ownerTrace"]
    },
    {
      "id": "missing-placement-anchor",
      "problem": "A semantic placement references an anchor that is not yet known in ProjectWorld or the placement context.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "owner-diagnostic",
      "prohibitedDslExpansions": ["ask LLM2 for exact anchor coordinates", "place at x y"],
      "resultCardEvidence": ["diagnostics", "ownerTrace"]
    },
    {
      "id": "ui-overlap",
      "problem": "Two UI controls overlap after placement.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "avoidance-rewrite",
      "prohibitedDslExpansions": ["ask LLM2 for another coordinate"],
      "resultCardEvidence": ["diagnostics", "placementResolutions", "ownerTrace"]
    },
    {
      "id": "front-direction-context",
      "problem": "The meaning of front differs by camera mode and game type.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "contextual-direction-rewrite",
      "prohibitedDslExpansions": ["frontInPlatformer", "frontInShooter"],
      "resultCardEvidence": ["rewrites", "resolved", "ownerTrace"]
    },
    {
      "id": "object-relative-placement",
      "problem": "World objects need concrete positions relative to an anchor object without exposing coordinates to LLM2.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "placement-contract",
      "prohibitedDslExpansions": ["place at x y", "anchor.x plus 32"],
      "resultCardEvidence": ["placementResolutions", "resolved", "ownerTrace"]
    },
    {
      "id": "semantic-pattern-placement",
      "problem": "Groups such as trails, lines, stairs, or guards need repeated concrete placements from one semantic intent.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "placement-contract",
      "prohibitedDslExpansions": ["place every coin by coordinate", "repeat coordinate list"],
      "resultCardEvidence": ["placementResolutions", "resolved", "ownerTrace"]
    },
    {
      "id": "semantic-placement-edit",
      "problem": "Existing objects need small relative placement edits from semantic amounts such as slightly above.",
      "routeOwner": "placement-resolver",
      "routeMechanism": "edit-constraint-planner",
      "prohibitedDslExpansions": ["move object by dy", "set object y coordinate"],
      "resultCardEvidence": ["editConstraints", "placementResolutions", "ownerTrace"]
    },
    {
      "id": "collision-mask-setup",
      "problem": "GDJS collision mask needs generated shape setup.",
      "routeOwner": "gdjs-bridge",
      "routeMechanism": "target-code-expansion",
      "prohibitedDslExpansions": ["collision mask rectangle ..."],
      "resultCardEvidence": ["emitted", "ownerTrace"]
    },
    {
      "id": "awkward-gdjs-parameters",
      "problem": "A GDJS instruction has awkward parameter order or target-specific naming.",
      "routeOwner": "gdjs-bridge",
      "routeMechanism": "target-rewrite",
      "prohibitedDslExpansions": ["set gdjs parameter ..."],
      "resultCardEvidence": ["rewrites", "emitted", "ownerTrace"]
    },
    {
      "id": "inventory-expansion",
      "problem": "Inventory needs storage variables, UI grid, and open/close bindings.",
      "routeOwner": "component-expander",
      "routeMechanism": "component-expansion",
      "prohibitedDslExpansions": ["create inventory slot object one by one"],
      "resultCardEvidence": ["emitted", "rewrites", "ownerTrace"]
    },
    {
      "id": "inventory-persistence",
      "problem": "Inventory persistence needs save/load runtime details.",
      "routeOwner": "runtime-adapter",
      "routeMechanism": "adapter-config",
      "prohibitedDslExpansions": ["save inventory with gdjs storage key ..."],
      "resultCardEvidence": ["runtimeAdapters", "diagnostics", "ownerTrace"]
    },
    {
      "id": "networked-touch-input",
      "problem": "Networked touch input must feed lockstep or server-authoritative input frames.",
      "routeOwner": "binding-compiler",
      "routeMechanism": "action-to-network-input-binding",
      "prohibitedDslExpansions": ["send touch event over network"],
      "resultCardEvidence": ["bindings", "emitted", "ownerTrace"]
    },
    {
      "id": "internal-target-execution",
      "problem": "A compiled internal target command failed while mutating the engine project.",
      "routeOwner": "runtime-executor",
      "routeMechanism": "execution-report",
      "prohibitedDslExpansions": ["ask LLM2 to repair internal target instructions"],
      "resultCardEvidence": ["executionReport", "runtimeFailureSummary", "ownerTrace"]
    },
    {
      "id": "missing-gdjs-runtime-include",
      "problem": "A GDJS runtime file/include is missing for the generated target.",
      "routeOwner": "gdevelop-truth",
      "routeMechanism": "truth-or-exporter-update",
      "prohibitedDslExpansions": ["include gdjs file ..."],
      "resultCardEvidence": ["diagnostics", "ownerTrace"]
    },
    {
      "id": "new-reusable-game-system",
      "problem": "The request names a genuinely new reusable game-world system.",
      "routeOwner": "component-catalog",
      "routeMechanism": "new-component-or-module-candidate",
      "prohibitedDslExpansions": ["generic internal target command expansion"],
      "resultCardEvidence": ["diagnostics", "ownerTrace"]
    }
  ],
  "rewriteContract": {
    "requiredFields": [
      "from",
      "to",
      "owner",
      "mechanism",
      "stage"
    ],
    "allowedOwners": [
      "intent-compiler",
      "component-catalog"
    ],
    "allowedMechanisms": [
      "module-inference",
      "component-alias",
      "natural-anchor",
      "screen-edge-anchor",
      "semantic-group"
    ]
  },
  "resultCard": {
    "requiredFields": [
      "input",
      "resolved",
      "rewrites",
      "overrides",
      "autoAdded",
      "emitted",
      "diagnostics",
      "warnings",
      "ownerTrace"
    ]
  }
}
