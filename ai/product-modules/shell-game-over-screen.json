{
  "schemaVersion": 1,
  "id": "shell.game_over_screen",
  "name": "Game Over Screen",
  "summary": "A fail-state scene and restart action for core gameplay modules.",
  "llm1Card": "Add a game over screen after the player fails.",
  "category": "shell",
  "defaultPreset": "basic",
  "presets": {
    "basic": {
      "description": "Game over text and a keyboard restart rule."
    }
  },
  "repositoryPolicy": {
    "preferReuse": true,
    "cloudRepoEligible": true,
    "promoteGeneratedVariants": true,
    "promotionTarget": "cloudModuleRepo",
    "trainingEligible": false
  },
  "defaults": {
    "scene": "GameOver",
    "targetScene": "Game",
    "title": "Game Over",
    "hint": "Press Space"
  },
  "sync": {
    "default": {
      "sync": "local",
      "authority": "client",
      "tickRate": 0,
      "seed": "auto"
    },
    "supported": {
      "sync": ["local", "event"],
      "authority": ["client", "host", "server"]
    },
    "deterministic": true,
    "inputs": ["restart"],
    "state": []
  },
  "interaction": {
    "fixedTriggers": [
      {
        "id": "restart",
        "labelParam": "hint",
        "kind": "key",
        "key": "Space",
        "description": "The game restarts when the player presses Space.",
        "copyRules": {
          "requiredAny": ["space", "空格"],
          "forbiddenTerms": ["enter", "return", "回车", "mouse", "click", "点击"]
        }
      }
    ]
  },
  "compiler": {
    "configurePatches": {
      "title": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on start -> text GameOverText \"{{title}}\"",
          "indexParam": "titleEventIndex"
        },
        "dsl": [
          "remove event #{{titleEventIndex}} scene={{scene}}",
          "on start -> text GameOverText {{title}} scene={{scene}}"
        ]
      },
      "hint": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on start -> text RestartHint \"{{hint}}\"",
          "indexParam": "hintEventIndex"
        },
        "dsl": [
          "remove event #{{hintEventIndex}} scene={{scene}}",
          "on start -> text RestartHint {{hint}} scene={{scene}}"
        ]
      },
      "targetScene": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on key Space -> scene {{targetScene}}",
          "indexParam": "targetSceneEventIndex"
        },
        "dsl": [
          "remove event #{{targetSceneEventIndex}} scene={{scene}}",
          "on key Space -> scene {{targetScene}} scene={{scene}}"
        ]
      }
    },
    "links": [
      {
        "targetModule": "core.platformer",
        "slot": "failAction",
        "value": "scene {{scene}}"
      }
    ],
    "dsl": [
      "create scene name={{scene}} first=false",
      "create object name=GameOverText type=Text size=40 scene={{scene}}",
      "create object name=RestartHint type=Text size=22 scene={{scene}}",
      "place object=GameOverText at=285,240 scene={{scene}}",
      "place object=RestartHint at=330,310 scene={{scene}}",
      "on start -> text GameOverText {{title}} scene={{scene}}",
      "on start -> text RestartHint {{hint}} scene={{scene}}",
      "on key Space -> scene {{targetScene}} scene={{scene}}"
    ]
  }
}
