{
  "schemaVersion": 1,
  "id": "core.idle_clicker",
  "revision": "local-v1",
  "name": "Idle Clicker Core",
  "summary": "A playable click-to-earn loop with passive growth and upgrades.",
  "llm1Card": "An idle clicker: click for coins, earn passively, and upgrade production.",
  "category": "core",
  "defaultPreset": "single-screen",
  "presets": {
    "single-screen": { "description": "Single-screen clicker." },
    "staged-zones": { "description": "Progression zones." }
  },
  "repositoryPolicy": {
    "preferReuse": true,
    "cloudRepoEligible": true,
    "promoteGeneratedVariants": true,
    "promotionTarget": "cloudModuleRepo",
    "trainingEligible": false
  },
  "semanticContract": {
    "provides": [
      "semantic-dictionary#/playGoals/grow",
      "semantic-dictionary#/semantic_concepts/resource_conversion",
      "semantic-dictionary#/eventMeanings/UpgradeApplied"
    ],
    "requires": [],
    "goals": ["semantic-dictionary#/playGoals/grow"],
    "roles": [
      "semantic-dictionary#/gameplayRoles/action_entry",
      "semantic-dictionary#/gameplayRoles/feedback"
    ],
    "pressures": [],
    "rewards": ["semantic-dictionary#/gameplayRoles/reward"]
  },
  "spatialContract": {
    "supportedTopologies": ["single-screen", "staged-zones"],
    "requiredRoles": ["actor_spawn"],
    "optionalRoles": ["goal_zone"],
    "constraints": [],
    "variationParameters": ["variationSeed"]
  },
  "declarationContract": {
    "spatialSubjects": [
      {
        "subjectId": "clicker",
        "prototypeId": "Clicker",
        "semanticRoleRefs": ["semantic-dictionary#/gameplayRoles/action_entry"],
        "bounds": { "width": 96, "height": 96, "anchor": "center" },
        "layerRole": "world",
        "cardinality": "exclusive",
        "placementPolicy": "actor_spawn"
      }
    ],
    "sharedArtifacts": [],
    "visualSlots": [
      {
        "visualSlotId": "idle.clicker.visual",
        "scene": "Game",
        "targetObject": "Clicker",
        "role": "idle-clicker",
        "allowedBindingModes": ["object-resource"],
        "requiredAssetKind": "sprite",
        "preserve": ["behaviors", "collisionMask", "variables", "instanceIdentity", "layer", "zOrderPolicy"]
      }
    ]
  },
  "lifecycleContract": {
    "start": "provided",
    "pause": "required",
    "failure": "required",
    "restart": "provided",
    "continue": "provided"
  },
  "ownershipContract": {
    "artifacts": [],
    "cleanupOrder": [],
    "stateMigrationPolicy": "preserve"
  },
  "acceptanceContract": {
    "createFixture": "idle-clicker.single-screen",
    "continueFixture": "idle-clicker.continue",
    "failureFixtures": [],
    "supportedLayoutFixtures": [
      "idle-clicker.single-screen",
      "idle-clicker.staged-zones"
    ],
    "playGoals": ["semantic-dictionary#/playGoals/grow"]
  },
  "defaults": { "scene": "Game" },
  "compiler": {
    "slots": {},
    "slotUpdateTemplates": {},
    "configureUpdateTemplates": {},
    "targetPlan": [
      "create scene name={{scene}} first=true",
      "create object name=Clicker type=ShapePainter shape=circle color=#FFD700 width=96 height=96 scene={{scene}}",
      "create object name=Upgrade type=ShapePainter shape=rectangle color=#44AAFF width=120 height=48 scene={{scene}}",
      "set variable name=Coins value=0 type=Number scope=global",
      "set variable name=Production value=1 type=Number scope=global",
      "place object=Clicker at=400,260 scene={{scene}}",
      "place object=Upgrade at=400,440 scene={{scene}}",
      "on mouse Clicker -> Coins=1 scene={{scene}}",
      "every 1s -> Coins=1 scene={{scene}}",
      "on mouse Upgrade -> Production=2 scene={{scene}}"
    ]
  },
  "networking": {
    "supports": {
      "syncModels": ["local"],
      "authority": ["host"],
      "players": { "min": 1, "max": 1 }
    },
    "determinism": {
      "supported": true,
      "requiresSeededRNG": false,
      "requiresFixedTimestep": false
    },
    "inputs": ["click"],
    "state": ["Coins", "Production"],
    "default": {
      "sync": "local",
      "authority": "host",
      "tickRate": 0,
      "seed": "auto"
    }
  },
  "capabilities": [
    {
      "id": "capability.idle.clicker",
      "name": "Idle clicker",
      "summary": "Click and passive production.",
      "llm1Hint": "Earn and upgrade.",
      "provides": ["idle_growth"],
      "requires": {
        "objects": [],
        "variables": [],
        "behaviors": [],
        "events": []
      },
      "constraints": {},
      "networking": {
        "supports": {
          "syncModels": [],
          "authority": [],
          "players": { "min": 1, "max": 1 }
        },
        "determinism": {
          "supported": true,
          "requiresSeededRNG": false,
          "requiresFixedTimestep": false
        },
        "inputs": [],
        "state": []
      }
    }
  ]
}
