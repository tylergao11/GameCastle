{
  "schemaVersion": 1,
  "id": "shell.start_screen",
  "revision": "local-v1",
  "name": "Start Screen",
  "summary": "A lightweight start scene that launches the main game scene.",
  "llm1Card": "Add a start screen before gameplay.",
  "category": "shell",
  "defaultPreset": "basic",
  "presets": {
    "basic": {
      "description": "Title text and a start button."
    }
  },
  "repositoryPolicy": {
    "preferReuse": true,
    "cloudRepoEligible": true,
    "promoteGeneratedVariants": true,
    "promotionTarget": "cloudModuleRepo",
    "trainingEligible": false
  },
  "semanticContract": { "provides": ["semantic-dictionary#/gameplayRoles/action_entry"], "requires": [], "goals": [], "roles": ["semantic-dictionary#/gameplayRoles/action_entry"], "pressures": [], "rewards": [] },
  "spatialContract": { "supportedTopologies": ["single-screen"], "requiredRoles": [], "optionalRoles": ["start"], "constraints": [], "variationParameters": [] },
  "declarationContract": { "spatialSubjects": [], "sharedArtifacts": [] },
  "lifecycleContract": { "start": "provided", "pause": "required", "failure": "required", "restart": "required", "continue": "provided" },
  "ownershipContract": { "artifacts": [], "cleanupOrder": [], "stateMigrationPolicy": "none" },
  "acceptanceContract": { "createFixture": "start.create", "continueFixture": "start.continue", "failureFixtures": [], "supportedLayoutFixtures": ["start.menu"], "playGoals": [] },
  "defaults": {
    "scene": "Start",
    "targetScene": "Game",
    "title": "GameCastle",
    "button": "Start"
  },
  "interaction": {
    "fixedTriggers": [
      {
        "id": "start",
        "labelParam": "button",
        "kind": "mouse_object",
        "object": "StartButton",
        "description": "The game starts by clicking the StartButton object.",
        "copyRules": {
          "forbiddenTerms": [
            "enter",
            "return",
            "space",
            "esc",
            "escape",
            "回车",
            "空格"
          ]
        }
      }
    ]
  },
  "compiler": {
    "configureUpdateTemplates": {
      "title": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on start -> text TitleText \"{{title}}\"",
          "indexParam": "titleEventIndex"
        },
        "targetPlan": [
          "remove event #{{titleEventIndex}} scene={{scene}}",
          "on start -> text TitleText {{title}} scene={{scene}}"
        ]
      },
      "button": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on start -> text StartLabel \"{{button}}\"",
          "indexParam": "buttonEventIndex"
        },
        "targetPlan": [
          "remove event #{{buttonEventIndex}} scene={{scene}}",
          "on start -> text StartLabel {{button}} scene={{scene}}"
        ]
      },
      "targetScene": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on mouse StartButton -> scene {{targetScene}}",
          "indexParam": "targetSceneEventIndex"
        },
        "targetPlan": [
          "remove event #{{targetSceneEventIndex}} scene={{scene}}",
          "on mouse StartButton -> scene {{targetScene}} scene={{scene}}"
        ]
      }
    },
    "targetPlan": [
      "create scene name={{scene}} first=true",
      "create object name=TitleText type=Text size=36 scene={{scene}}",
      "create object name=StartButton type=ShapePainter shape=rectangle color=#2ECC71 width=180 height=56 scene={{scene}}",
      "create object name=StartLabel type=Text size=24 scene={{scene}}",
      "place object=TitleText at=280,170 scene={{scene}}",
      "place object=StartButton at=310,300 scene={{scene}} width=180 height=56",
      "place object=StartLabel at=360,315 scene={{scene}}",
      "on start -> text TitleText {{title}} scene={{scene}}",
      "on start -> text StartLabel {{button}} scene={{scene}}",
      "on mouse StartButton -> scene {{targetScene}} scene={{scene}}"
    ]
  },
  "networking": {
    "supports": {
      "syncModels": [
        "local",
        "event"
      ],
      "authority": [
        "client",
        "host",
        "server"
      ],
      "players": {
        "min": 1,
        "max": 4
      }
    },
    "determinism": {
      "supported": true,
      "requiresSeededRNG": true,
      "requiresFixedTimestep": true
    },
    "inputs": [
      "start"
    ],
    "state": [],
    "default": {
      "sync": "local",
      "authority": "client",
      "tickRate": 0,
      "seed": "auto"
    }
  },
  "provides": {
    "ui": [
      "start screen"
    ],
    "configurable": [
      "title",
      "button",
      "targetScene"
    ]
  },
  "requires": {
    "scene": "Start"
  },
  "capabilities": [
    {
      "id": "capability.object.shape",
      "name": "Shape objects and text",
      "summary": "Create visible game objects using ShapePainter rectangles/circles and Text objects.",
      "llm1Hint": "Visuals use simple colored shapes and text.",
      "provides": [
        "shape_object",
        "text_object",
        "simple_visuals"
      ],
      "requires": {
        "objects": [],
        "variables": [],
        "behaviors": [],
        "events": []
      },
      "constraints": {
        "objectNames": "Use stable English names.",
        "shapePainter": "ShapePainter objects must include shape, color, width, and height.",
        "colors": "Use #RRGGBB."
      },
      "networking": {
        "supports": {
          "syncModels": [],
          "authority": [],
          "players": {
            "min": 1,
            "max": 4
          }
        },
        "determinism": {
          "supported": true,
          "requiresSeededRNG": true,
          "requiresFixedTimestep": true
        },
        "inputs": [],
        "state": []
      }
    },
    {
      "id": "capability.scene.base",
      "name": "Base scene",
      "summary": "Create the playable scene and base canvas for a GameCastle project.",
      "llm1Hint": "A game can have one main playable scene on an 800x600 canvas.",
      "provides": [
        "main_scene",
        "playable_canvas"
      ],
      "requires": {
        "objects": [],
        "variables": [],
        "behaviors": [],
        "events": []
      },
      "constraints": {
        "sceneName": "Use Game unless the user explicitly asks for another scene.",
        "canvas": {
          "width": 800,
          "height": 600
        }
      },
      "networking": {
        "supports": {
          "syncModels": [],
          "authority": [],
          "players": {
            "min": 1,
            "max": 4
          }
        },
        "determinism": {
          "supported": true,
          "requiresSeededRNG": true,
          "requiresFixedTimestep": true
        },
        "inputs": [],
        "state": []
      }
    }
  ]
}
