{
  "schemaVersion": 1,
  "id": "core.platformer",
  "revision": "local-v1",
  "name": "Platformer Core",
  "summary": "A playable side-view platform game loop with player movement, platforms, coins, score, hazards, and a fail rule.",
  "llm1Card": "A complete platformer game core: move, jump, collect coins, avoid hazards, and score.",
  "category": "core",
  "defaultPreset": "basic",
  "presets": {
    "basic": {
      "description": "Small playable platformer suitable as a first generated version."
    },
    "mobile": {
      "description": "Platformer core prepared for mobile controls supplied by the Intent component bridge."
    }
  },
  "repositoryPolicy": {
    "preferReuse": true,
    "cloudRepoEligible": true,
    "promoteGeneratedVariants": true,
    "promotionTarget": "cloudModuleRepo",
    "trainingEligible": false
  },
  "semanticContract": { "provides": ["semantic-dictionary#/semantic_concepts/movement", "semantic-dictionary#/playGoals/collect", "semantic-dictionary#/playGoals/avoid-threats", "semantic-dictionary#/eventMeanings/ActorFailed"], "requires": [], "goals": ["semantic-dictionary#/playGoals/collect"], "roles": ["semantic-dictionary#/gameplayRoles/actor", "semantic-dictionary#/gameplayRoles/reward", "semantic-dictionary#/gameplayRoles/pressure"], "pressures": ["semantic-dictionary#/gameplayRoles/pressure"], "rewards": ["semantic-dictionary#/gameplayRoles/reward"] },
  "mechanicRevisionRefs": [{ "mechanicId": "motion.platform", "revision": 1, "contentHash": "9eac95e61df5602692a595ecebd7da2b934b41b1e1976a4ad8f1d5eb1ecc7f92" }, { "mechanicId": "space.route", "revision": 1, "contentHash": "caa98d691f35709b5ee6ac4b165d94b7ee4965739a92b513c2e604a8a2e50abf" }],
  "spatialContract": { "supportedTopologies": ["linear", "branching-route"], "requiredRoles": ["actor_spawn", "active_route", "reward_zone", "pressure_zone"], "optionalRoles": ["goal_zone"], "constraints": [], "variationParameters": ["variationSeed"] },
  "declarationContract": { "spatialSubjects": [{ "subjectId": "player", "prototypeId": "Player", "semanticRoleRefs": ["semantic-dictionary#/gameplayRoles/actor"], "bounds": { "width": 32, "height": 48, "anchor": "bottom-center" }, "layerRole": "world", "cardinality": "exclusive", "placementPolicy": "actor_spawn" }, { "subjectId": "coin", "prototypeId": "Coin", "semanticRoleRefs": ["semantic-dictionary#/gameplayRoles/reward"], "bounds": { "width": 16, "height": 16, "anchor": "center" }, "layerRole": "world", "cardinality": "composed", "placementPolicy": "reward_zone" }, { "subjectId": "enemy", "prototypeId": "Enemy", "semanticRoleRefs": ["semantic-dictionary#/gameplayRoles/pressure"], "bounds": { "width": 32, "height": 32, "anchor": "bottom-center" }, "layerRole": "world", "cardinality": "composed", "placementPolicy": "pressure_zone" }], "sharedArtifacts": [] },
  "lifecycleContract": { "start": "provided", "pause": "required", "failure": "provided", "restart": "provided", "continue": "provided" },
  "ownershipContract": { "artifacts": [], "cleanupOrder": [], "stateMigrationPolicy": "none" },
  "acceptanceContract": { "createFixture": "runner-platformer.linear", "continueFixture": "runner-platformer.continue", "failureFixtures": ["runner-platformer.failure"], "supportedLayoutFixtures": ["runner-platformer.linear", "runner-platformer.branching"], "playGoals": ["semantic-dictionary#/playGoals/collect"] },
  "defaults": {
    "scene": "Game",
    "failAction": "restart"
  },
  "compiler": {
    "slots": {
      "failAction": "restart"
    },
    "slotUpdateTemplates": {
      "failAction": {
        "findEvent": {
          "sceneParam": "scene",
          "textPrefix": "on collision Player Enemy ->",
          "indexParam": "failEventIndex"
        },
        "targetPlan": [
          "remove event #{{failEventIndex}} scene={{scene}}",
          "on collision Player Enemy -> {{failAction}}"
        ]
      }
    },
    "targetPlan": [
      "create scene name={{scene}} first=true",
      "create object name=Player type=ShapePainter shape=rectangle color=#4488FF width=32 height=48 scene={{scene}}",
      "create object name=Ground type=ShapePainter shape=rectangle color=#8B4513 width=800 height=20 scene={{scene}}",
      "create object name=Platform type=ShapePainter shape=rectangle color=#8B4513 width=100 height=16 scene={{scene}}",
      "create object name=Coin type=ShapePainter shape=circle color=#FFD700 width=16 height=16 scene={{scene}}",
      "create object name=Enemy type=ShapePainter shape=rectangle color=#DC3232 width=32 height=32 scene={{scene}}",
      "add behavior type=PlatformBehavior::PlatformerObjectBehavior to=Player scene={{scene}}",
      "add behavior type=PlatformBehavior::PlatformBehavior to=Ground scene={{scene}}",
      "add behavior type=PlatformBehavior::PlatformBehavior to=Platform scene={{scene}}",
      "set variable name=Score value=0 type=Number scope=global",
      "place object=Player at=100,400 scene={{scene}}",
      "place object=Ground at=400,590 scene={{scene}} width=800 height=20",
      "place object=Platform at=200,460 scene={{scene}} width=100 height=16",
      "place object=Platform at=400,380 scene={{scene}} width=100 height=16",
      "place object=Platform at=600,300 scene={{scene}} width=100 height=16",
      "place object=Coin at=240,430 scene={{scene}}",
      "place object=Coin at=440,350 scene={{scene}}",
      "place object=Coin at=640,270 scene={{scene}}",
      "place object=Enemy at=550,400 scene={{scene}}",
      "on start -> Score=0 scene={{scene}}",
      "on collision Player Coin -> destroy Coin, score+1 scene={{scene}}",
      "on collision Player Enemy -> {{failAction}} scene={{scene}}",
      "on key Space -> jump Player 500 scene={{scene}}"
    ]
  },
  "networking": {
    "supports": {
      "syncModels": [
        "local",
        "lockstep"
      ],
      "authority": [
        "host",
        "server"
      ],
      "players": {
        "min": 1,
        "max": 4
      }
    },
    "determinism": {
      "supported": true,
      "requiresSeededRNG": true,
      "requiresFixedTimestep": true
    },
    "inputs": [
      "move_left",
      "move_right",
      "jump"
    ],
    "state": [
      "Score",
      "Player",
      "Coin",
      "Enemy"
    ],
    "default": {
      "sync": "local",
      "authority": "host",
      "tickRate": 20,
      "seed": "auto"
    }
  },
  "provides": {
    "gameLoop": "platformer",
    "playerCount": {
      "min": 1,
      "max": 4
    },
    "objects": [
      "Player",
      "Ground",
      "Platform",
      "Coin",
      "Enemy"
    ],
    "behaviors": [
      "PlatformBehavior::PlatformerObjectBehavior",
      "PlatformBehavior::PlatformBehavior"
    ],
    "inputs": [
      "space"
    ]
  },
  "requires": {
    "scene": "Game"
  },
  "capabilities": [
