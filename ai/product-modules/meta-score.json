{
  "schemaVersion": 1,
  "id": "meta.score",
  "revision": "local-v1",
  "name": "Score Meta",
  "summary": "Score state and score display support that complements game cores needing scoring.",
  "llm1Card": "Track and display a score.",
  "category": "meta",
  "incompatibleWith": [
    "core.platformer"
  ],
  "defaultPreset": "basic",
  "presets": {
    "basic": {
      "description": "Global Score variable and display text."
    }
  },
  "repositoryPolicy": {
    "preferReuse": true,
    "cloudRepoEligible": true,
    "promoteGeneratedVariants": true,
    "promotionTarget": "cloudModuleRepo",
    "trainingEligible": false
  },
  "semanticContract": { "provides": ["semantic-dictionary#/gameplayRoles/feedback"], "requires": [], "goals": [], "roles": ["semantic-dictionary#/gameplayRoles/feedback"], "pressures": [], "rewards": [] },
  "spatialContract": { "supportedTopologies": ["linear", "arena", "rooms", "grid", "lanes", "single-screen", "staged-zones"], "requiredRoles": [], "optionalRoles": ["hud", "score"], "constraints": [], "variationParameters": [] },
  "declarationContract": { "spatialSubjects": [], "sharedArtifacts": [] },
  "lifecycleContract": { "start": "required", "pause": "required", "failure": "required", "restart": "required", "continue": "provided" },
  "ownershipContract": { "artifacts": [], "cleanupOrder": [], "stateMigrationPolicy": "preserve" },
  "acceptanceContract": { "createFixture": "score.create", "continueFixture": "score.continue", "failureFixtures": [], "supportedLayoutFixtures": ["score.hud"], "playGoals": [] },
  "defaults": {
    "scene": "Game"
  },
  "compiler": {
    "targetPlan": [
      "set variable name=Score value=0 type=Number scope=global",
      "create object name=ScoreText type=Text size=22 scene={{scene}}",
      "place object=ScoreText at=20,20 scene={{scene}}",
      "on start -> Score=0 scene={{scene}}",
      "on start -> text ScoreText Score scene={{scene}}"
    ]
  },
  "networking": {
    "supports": {
      "syncModels": [
        "local",
        "lockstep",
        "snapshot"
      ],
      "authority": [
        "host",
        "server"
      ],
      "players": {
        "min": 1,
        "max": 4
      }
    },
    "determinism": {
      "supported": true,
      "requiresSeededRNG": true,
      "requiresFixedTimestep": true
    },
    "inputs": [],
    "state": [
      "Score"
    ],
    "default": {
      "sync": "local",
      "authority": "host",
      "tickRate": 60,
      "seed": "auto"
    }
  },
  "provides": {
    "feature": "score",
    "variables": [
      "Score"
    ]
  },
  "requires": {
    "scene": "Game"
  },
  "capabilities": [
    {
      "id": "capability.collectible.score",
      "name": "Collectible scoring",
      "summary": "Collect objects, destroy the collected item, and update a score variable.",
      "llm1Hint": "Players can collect items such as coins or gems for score.",
      "provides": [
        "collectible",
        "score",
        "pickup_loop"
      ],
      "requires": {
        "objects": [
          "player",
          "collectible"
        ],
        "variables": [
          "Score"
        ],
        "behaviors": [],
        "events": [
          "collision_collectible"
        ]
      },
      "constraints": {
        "scoreVariable": "Use Score as the default global score variable.",
        "pickupAction": "A collectible collision should remove the collected object."
      },
      "networking": {
        "supports": {
          "syncModels": [],
          "authority": [],
          "players": {
            "min": 1,
            "max": 4
          }
        },
        "determinism": {
          "supported": true,
          "requiresSeededRNG": true,
          "requiresFixedTimestep": true
        },
        "inputs": [],
        "state": []
      }
    },
    {
      "id": "capability.object.shape",
      "name": "Shape objects and text",
      "summary": "Create visible game objects using ShapePainter rectangles/circles and Text objects.",
      "llm1Hint": "Visuals use simple colored shapes and text.",
      "provides": [
        "shape_object",
        "text_object",
        "simple_visuals"
      ],
      "requires": {
        "objects": [],
        "variables": [],
        "behaviors": [],
        "events": []
      },
      "constraints": {
        "objectNames": "Use stable English names.",
        "shapePainter": "ShapePainter objects must include shape, color, width, and height.",
        "colors": "Use #RRGGBB."
      },
      "networking": {
        "supports": {
          "syncModels": [],
          "authority": [],
          "players": {
            "min": 1,
            "max": 4
          }
        },
        "determinism": {
          "supported": true,
          "requiresSeededRNG": true,
          "requiresFixedTimestep": true
        },
        "inputs": [],
        "state": []
      }
    },
    {
      "id": "capability.scene.base",
      "name": "Base scene",
      "summary": "Create the playable scene and base canvas for a GameCastle project.",
      "llm1Hint": "A game can have one main playable scene on an 800x600 canvas.",
      "provides": [
        "main_scene",
        "playable_canvas"
      ],
      "requires": {
        "objects": [],
        "variables": [],
        "behaviors": [],
        "events": []
      },
      "constraints": {
        "sceneName": "Use Game unless the user explicitly asks for another scene.",
        "canvas": {
          "width": 800,
          "height": 600
        }
      },
      "networking": {
        "supports": {
          "syncModels": [],
          "authority": [],
          "players": {
            "min": 1,
            "max": 4
          }
        },
        "determinism": {
          "supported": true,
          "requiresSeededRNG": true,
          "requiresFixedTimestep": true
        },
        "inputs": [],
        "state": []
      }
    }
  ]
}
