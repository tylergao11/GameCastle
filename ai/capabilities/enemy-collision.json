{
  "schemaVersion": 1,
  "id": "capability.enemy.collision",
  "name": "Enemy collision hazard",
  "summary": "Create enemies or hazards that punish the player on collision.",
  "llm1Hint": "Enemies and hazards can reset, defeat, or otherwise punish the player.",
  "provides": [
    "enemy",
    "hazard",
    "lose_condition"
  ],
  "requires": {
    "objects": [
      "player",
      "enemy"
    ],
    "variables": [],
    "behaviors": [],
    "events": [
      "collision_hazard"
    ]
  },
  "dsl": {
    "commands": [
      "on collision <PlayerObject> <EnemyObject> -> restart",
      "on collision <PlayerObject> <EnemyObject> -> scene <SceneName>",
      "delete object name=<EnemyObject> scene=<SceneName>"
    ],
    "examples": [
      "on collision Player Enemy -> restart"
    ]
  },
  "constraints": {
    "feedback": "For the current runtime slice, restart is the safest default punishment.",
    "placement": "Place enemies away from the initial player spawn unless the user asks for high difficulty."
  },
  "networking": {
    "supports": {
      "syncModels": [],
      "authority": [],
      "players": {
        "min": 1,
        "max": 4
      }
    },
    "determinism": {
      "supported": true,
      "requiresSeededRNG": true,
      "requiresFixedTimestep": true
    },
    "inputs": [],
    "state": []
  }
}
