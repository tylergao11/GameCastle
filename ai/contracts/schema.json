{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gamecastle.local/ai/contracts/schema.json",
  "schemaVersion": 1,
  "description": "GameCastle multi-agent contract schemas. LLM agents translate intent; RuntimeAssetResolver owns asset reuse/generation routing/fallback; runtime Linker/Validator owns deterministic merge and verification.",
  "contractTypes": [
    "BuildContract",
    "ModuleDslPatch",
    "AssetManifest",
    "AssetReview",
    "AssemblyReport",
    "ValidationReport",
    "DistillHint"
  ],
  "$defs": {
    "ContractMeta": {
      "type": "object",
      "required": [
        "schemaVersion",
        "contractId",
        "createdAt",
        "owner",
        "status"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "contractId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO-8601 timestamp."
        },
        "owner": {
          "type": "string",
          "enum": [
            "RequirementModel",
            "DSLAgent",
            "ModuleCompiler",
            "RuntimeAssetResolver",
            "RuntimeExecutor",
            "ImageAgent",
            "VisionAgent",
            "RuntimeLinker",
            "RuntimeValidator"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready",
            "partial",
            "blocked",
            "failed",
            "passed"
          ]
        },
        "source": {
          "type": "object",
          "properties": {
            "userPrompt": {
              "type": "string"
            },
            "projectWorldHash": {
              "type": "string"
            },
            "baseProjectPath": {
              "type": "string"
            },
            "agentRunId": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "SyncPolicy": {
      "type": "object",
      "required": [
        "sync",
        "authority",
        "tickRate",
        "seed",
        "deterministic"
      ],
      "properties": {
        "sync": {
          "type": "string",
          "enum": [
            "local",
            "event",
            "snapshot",
            "lockstep"
          ]
        },
        "authority": {
          "type": "string",
          "enum": [
            "client",
            "host",
            "server",
            "runtime"
          ]
        },
        "tickRate": {
          "type": "integer",
          "minimum": 0
        },
        "seed": {
          "type": [
            "string",
            "integer"
          ]
        },
        "deterministic": {
          "type": "boolean"
        },
        "networkState": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "networkInputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "AssetSlot": {
      "type": "object",
      "required": [
        "slotId",
        "kind",
        "purpose",
        "required",
        "owner",
        "target",
        "semanticTags",
        "styleTags",
        "constraints",
        "repoPolicy",
        "resolutionPolicy",
        "fallback",
        "publishPolicy"
      ],
      "properties": {
        "slotId": {
          "type": "string",
          "pattern": "^asset\\.[a-zA-Z0-9_.-]+$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "sprite",
            "background",
            "ui",
            "icon",
            "tile",
            "effect",
            "model3d",
            "texture",
            "audio"
          ]
        },
        "purpose": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "owner": {
          "const": "RuntimeAssetResolver"
        },
        "semanticTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "styleTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target": {
          "type": "object",
          "required": [
            "scene",
            "object",
            "binding"
          ],
          "properties": {
            "scene": {
              "type": [
                "string",
                "null"
              ]
            },
            "object": {
              "type": [
                "string",
                "null"
              ]
            },
            "binding": {
              "type": "string",
              "enum": [
                "objectTexture",
                "background",
                "uiImage",
                "animationFrame",
                "material",
                "thumbnail",
                "audioResource"
              ]
            },
            "moduleId": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "constraints": {
          "type": "object",
          "required": [
            "width",
            "height",
            "transparent",
            "style",
            "semantic",
            "negative"
          ],
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "transparent": {
              "type": "boolean"
            },
            "aspectRatio": {
              "type": "string"
            },
            "style": {
              "type": "string"
            },
            "palette": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "semantic": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "negative": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "animation": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "states": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "framesPerState": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            },
            "collisionHint": {
              "type": "object",
              "properties": {
                "shape": {
                  "type": "string",
                  "enum": [
                    "none",
                    "rectangle",
                    "circle",
                    "polygon"
                  ]
                },
                "width": {
                  "type": "integer",
                  "minimum": 0
                },
                "height": {
                  "type": "integer",
                  "minimum": 0
                },
                "offsetX": {
                  "type": "integer"
                },
                "offsetY": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "repoPolicy": {
          "type": "object",
          "required": [
            "preferReuse",
            "lookupOrder",
            "maxCandidates",
            "allowCrossGameReuse",
            "allowLicensedAssets",
            "requiredLicense",
            "minConfidence"
          ],
          "properties": {
            "preferReuse": {
              "type": "boolean"
            },
            "lookupOrder": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "exactCache",
                  "cloudRepoExact",
                  "cloudRepoSemantic",
                  "cloudRepoStyle",
                  "localProject",
                  "variant",
                  "externalGeneration",
                  "runtimePlaceholder"
                ]
              }
            },
            "maxCandidates": {
              "type": "integer",
              "minimum": 1
            },
            "allowCrossGameReuse": {
              "type": "boolean"
            },
            "allowLicensedAssets": {
              "type": "boolean"
            },
            "requiredLicense": {
              "type": "string",
              "enum": [
                "owned",
                "commercial",
                "internal",
                "prototype",
                "any"
              ]
            },
            "minConfidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        },
        "resolutionPolicy": {
          "type": "object",
          "required": [
            "allowExactCache",
            "allowRepoMatch",
            "allowVariant",
            "allowGeneration",
            "allowPlaceholder",
            "visionReview"
          ],
          "properties": {
            "allowExactCache": {
              "type": "boolean"
            },
            "allowRepoMatch": {
              "type": "boolean"
            },
            "allowVariant": {
              "type": "boolean"
            },
            "allowGeneration": {
              "type": "boolean"
            },
            "allowPlaceholder": {
              "type": "boolean"
            },
            "visionReview": {
              "type": "string",
              "enum": [
                "never",
                "lowConfidence",
                "criticalAsset",
                "always"
              ]
            }
          },
          "additionalProperties": false
        },
        "fallback": {
          "type": "object",
          "required": [
            "strategy",
            "source",
            "publishable",
            "repoEligible",
            "trainingEligible",
            "blocksFinalExport",
            "debt"
          ],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": [
                "placeholder",
                "shapePainter",
                "blockAssembly"
              ]
            },
            "source": {
              "const": "runtimeFallback"
            },
            "placeholderColor": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "publishable": {
              "type": "boolean"
            },
            "repoEligible": {
              "type": "boolean"
            },
            "trainingEligible": {
              "type": "boolean"
            },
            "blocksFinalExport": {
              "type": "boolean"
            },
            "debt": {
              "type": "string",
              "enum": [
                "none",
                "asset_missing",
                "asset_low_confidence",
                "asset_generation_failed",
                "asset_validation_failed"
              ]
            }
          },
          "additionalProperties": false
        },
        "publishPolicy": {
          "type": "object",
          "required": [
            "playableWithPlaceholder",
            "publishableWithPlaceholder",
            "repoEligibleWhenGenerated",
            "trainingEligibleWhenGenerated"
          ],
          "properties": {
            "playableWithPlaceholder": {
              "type": "boolean"
            },
            "publishableWithPlaceholder": {
              "type": "boolean"
            },
            "repoEligibleWhenGenerated": {
              "type": "boolean"
            },
            "trainingEligibleWhenGenerated": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "cache": {
          "type": "object",
          "properties": {
            "promptHash": {
              "type": "string"
            },
            "seed": {
              "type": [
                "string",
                "integer"
              ]
            },
            "reuseAllowed": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ModuleIntent": {
      "type": "object",
      "required": [
        "moduleId",
        "preset",
        "action",
        "syncPolicy",
        "params"
      ],
      "properties": {
        "moduleId": {
          "type": "string"
        },
        "preset": {
          "type": "string"
        },
        "action": {
          "type": "string",
          "enum": [
            "install",
            "configure",
            "remove"
          ]
        },
        "syncPolicy": {
          "$ref": "#/$defs/SyncPolicy"
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "BuildContract": {
      "type": "object",
      "x-contractOwner": "RequirementModel",
      "required": [
        "meta",
        "request",
        "world",
        "styleGuide",
        "moduleContract",
        "assetContract",
        "parallelPlan",
        "acceptance",
        "cachePolicy",
        "repairPolicy"
      ],
      "properties": {
        "meta": {
          "$ref": "#/$defs/ContractMeta"
        },
        "request": {
          "type": "object",
          "required": [
            "rawUserPrompt",
            "projectMode",
            "iterationIntent"
          ],
          "properties": {
            "rawUserPrompt": {
              "type": "string"
            },
            "projectMode": {
              "type": "string",
              "enum": [
                "new",
                "continue",
                "repair"
              ]
            },
            "iterationIntent": {
              "type": "string"
            },
            "hardRequirements": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nonGoals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "world": {
          "type": "object",
          "required": [
            "projectWorldHash",
            "knownScenes",
            "knownModules"
          ],
          "properties": {
            "projectWorldHash": {
              "type": [
                "string",
                "null"
              ]
            },
            "knownScenes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "knownModules": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "styleGuide": {
          "type": "object",
          "required": [
            "visualStyle",
            "tone",
            "palette",
            "assetReuse"
          ],
          "properties": {
            "visualStyle": {
              "type": "string"
            },
            "tone": {
              "type": "string"
            },
            "palette": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "assetReuse": {
              "type": "string",
              "enum": [
                "reuseExisting",
                "generateMissingOnly",
                "regenerateAll"
              ]
            }
          },
          "additionalProperties": false
        },
        "moduleContract": {
          "type": "object",
          "required": [
            "moduleIntents",
            "gameplaySlots",
            "stateVariables",
            "networkPolicy"
          ],
          "properties": {
            "moduleIntents": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ModuleIntent"
              }
            },
            "gameplaySlots": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "stateVariables": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "networkPolicy": {
              "$ref": "#/$defs/SyncPolicy"
            }
          },
          "additionalProperties": false
        },
        "assetContract": {
          "type": "object",
          "required": [
            "slots",
            "globalConstraints",
            "resolutionDefaults"
          ],
          "properties": {
            "slots": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AssetSlot"
              }
            },
            "globalConstraints": {
              "type": "object",
              "required": [
                "allowTextInImages",
                "allowedFormats",
                "outputRoot",
                "cloudRepoRequired"
              ],
              "properties": {
                "allowTextInImages": {
                  "type": "boolean"
                },
                "allowedFormats": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "png",
                      "jpg",
                      "webp",
                      "glb",
                      "mp3",
                      "ogg"
                    ]
                  }
                },
                "outputRoot": {
                  "type": "string"
                },
                "cloudRepoRequired": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "resolutionDefaults": {
              "type": "object",
              "required": [
                "preferRepo",
                "generateOnlyOnMiss",
                "placeholderIsDebt",
                "cacheKeyFields"
              ],
              "properties": {
                "preferRepo": {
                  "type": "boolean"
                },
                "generateOnlyOnMiss": {
                  "type": "boolean"
                },
                "placeholderIsDebt": {
                  "type": "boolean"
                },
                "cacheKeyFields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "parallelPlan": {
          "type": "object",
          "required": [
            "canRunInParallel",
            "tasks",
            "joinStrategy"
          ],
          "properties": {
            "canRunInParallel": {
              "type": "boolean"
            },
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "taskId",
                  "owner",
                  "inputs",
                  "outputs",
                  "dependsOn"
                ],
                "properties": {
                  "taskId": {
                    "type": "string"
                  },
                  "owner": {
                    "type": "string",
                    "enum": [
                      "DSLAgent",
                      "ModuleCompiler",
                      "RuntimeAssetResolver",
                      "RuntimeExecutor",
                      "ImageAgent",
                      "VisionAgent"
                    ]
                  },
                  "inputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "outputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "dependsOn": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "joinStrategy": {
              "type": "string",
              "enum": [
                "allRequired",
                "allowVisualFallbacks",
                "manualApproval"
              ]
            }
          },
          "additionalProperties": false
        },
        "acceptance": {
          "type": "object",
          "required": [
            "runtime",
            "visual",
            "cache"
          ],
          "properties": {
            "runtime": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "visual": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cache": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "cachePolicy": {
          "type": "object",
          "required": [
            "semanticHashInputs",
            "assetHashInputs",
            "invalidateOn"
          ],
          "properties": {
            "semanticHashInputs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "assetHashInputs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "invalidateOn": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "repairPolicy": {
          "type": "object",
          "required": [
            "maxRounds",
            "routeByOwner",
            "retryOwners"
          ],
          "properties": {
            "maxRounds": {
              "type": "integer",
              "minimum": 0
            },
            "routeByOwner": {
              "type": "boolean"
            },
            "retryOwners": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "RequirementModel",
                  "DSLAgent",
                  "ModuleCompiler",
                  "RuntimeAssetResolver",
                  "RuntimeExecutor",
                  "ImageAgent",
                  "VisionAgent",
                  "RuntimeLinker"
                ]
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ModuleDslPatch": {
      "type": "object",
      "x-contractOwner": "ModuleCompiler",
      "required": [
        "meta",
        "buildContractId",
        "patchKind",
        "moduleDsl",
        "declaredAssetSlots",
        "expectedOutputs"
      ],
      "properties": {
        "meta": {
          "$ref": "#/$defs/ContractMeta"
        },
        "buildContractId": {
          "type": "string"
        },
        "patchKind": {
          "type": "string",
          "enum": [
            "module",
            "internalRepair"
          ]
        },
        "moduleDsl": {
          "type": "string"
        },
        "declaredAssetSlots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expectedOutputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "networkManifestPatch": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "AssetManifest": {
      "type": "object",
      "x-contractOwner": "RuntimeAssetResolver",
      "required": [
        "meta",
        "buildContractId",
        "assets",
        "summary"
      ],
      "properties": {
        "meta": {
          "$ref": "#/$defs/ContractMeta"
        },
        "buildContractId": {
          "type": "string"
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "slotId",
              "status",
              "source",
              "path",
              "format",
              "sha1",
              "width",
              "height",
              "transparent",
              "semanticTags",
              "styleTags",
              "confidence",
              "publishability",
              "resolution"
            ],
            "properties": {
              "slotId": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "reused",
                  "variant",
                  "generated",
                  "placeholder",
                  "failed"
                ]
              },
              "source": {
                "type": "string",
                "enum": [
                  "exactCache",
                  "cloudRepo",
                  "localProject",
                  "generatedExternal",
                  "runtimeFallback"
                ]
              },
              "assetId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "repoAssetId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "provider": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "path": {
                "type": "string"
              },
              "format": {
                "type": "string"
              },
              "sha1": {
                "type": "string"
              },
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              },
              "transparent": {
                "type": "boolean"
              },
              "semanticTags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "styleTags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "prompt": {
                "type": "string"
              },
              "negativePrompt": {
                "type": "string"
              },
              "seed": {
                "type": [
                  "string",
                  "integer",
                  "null"
                ]
              },
              "reason": {
                "type": "string"
              },
              "cost": {
                "type": "object",
                "required": [
                  "currency",
                  "estimated",
                  "reason"
                ],
                "properties": {
                  "currency": {
                    "type": "string"
                  },
                  "estimated": {
                    "type": "number",
                    "minimum": 0
                  },
                  "reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "resolution": {
                "type": "object",
                "required": [
                  "strategy",
                  "rank",
                  "candidatesConsidered",
                  "cacheHit",
                  "ownerOnFailure"
                ],
                "properties": {
                  "strategy": {
                    "type": "string",
                    "enum": [
                      "exactCache",
                      "repoExact",
                      "repoSemantic",
                      "repoStyle",
                      "variant",
                      "generate",
                      "placeholder"
