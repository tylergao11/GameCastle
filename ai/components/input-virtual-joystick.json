        "input.control",
        "input.axis"
      ],
      "defaultOwner": "component-manifest",
      "exposedOverrides": [
        "action"
      ],
      "sealedDefaults": [
        "deadZone",
        "radius",
        "axisSmoothing",
        "shape",
        "color",
        "width",
        "height",
        "layer",
        "inputs"
      ]
    },
    "provides": [
      "input.move.axis"
    ],
    "requires": [
      {
        "componentId": "movement.platformer",
        "target": "sameTarget",
        "reason": "joystick movement needs a movement receiver"
      }
    ],
    "binding": {
