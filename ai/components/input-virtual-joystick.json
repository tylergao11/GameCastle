      "preferredAnchor": "screen",
      "preferredDirection": "bottom-left"
    },
    "gdjsBridge": {
      "objectSpec": {
        "type": "ShapePainter",
        "mechanism": "component-object-expansion",
        "routeId": "collision-mask-setup",
        "routeMechanism": "target-code-expansion",
        "layerEmission": {
          "mechanism": "component-ui-layer",
          "routeId": "responsive-ui",
          "routeMechanism": "placement-contract"
        },
        "placementEmission": {
          "mechanism": "component-placement-rewrite",
          "routeId": "awkward-gdjs-parameters",
          "routeMechanism": "target-rewrite"
        }
      },
      "runtimeAdapters": [
        "virtual-joystick"
      ],
      "adapterRoutes": {
        "virtual-joystick": {
          "owner": "runtime-adapter",
          "mechanism": "touch-axis-adapter",
          "routeId": "touch-multitouch-state",
          "routeOwner": "runtime-adapter",
          "routeMechanism": "bridge-target-rewrite"
        }
      },
      "status": "pending"
