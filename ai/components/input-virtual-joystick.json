{
  "schemaVersion": 1,
  "id": "input.virtual_joystick",
  "kind": "control",
  "name": "Virtual Joystick",
  "aiManifest": {
    "summary": "A mobile thumb control for moving the player.",
    "aliases": [
      "joystick",
      "virtual joystick",
      "movement joystick",
      "thumbstick"
    ],
    "actions": [
      "move"
    ],
    "targetRoles": [
      "player",
      "character"
    ],
    "safeExamples": [
      "add joystick controls Player near screen bottom-left"
    ]
  },
  "compilerManifest": {
    "componentId": "input.virtual_joystick",
    "thingName": "Joystick",
    "thingArchetype": "ui",
    "role": "control",
    "defaultAction": "move",
    "defaultConfig": {
      "action": "move",
      "deadZone": "standard",
      "radius": "medium",
      "axisSmoothing": "standard",
      "shape": "circle",
      "color": "#2D9CDB",
      "width": 96,
      "height": 96,
      "layer": "UI",
