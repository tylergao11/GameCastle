{
  "schemaVersion": 1,
  "id": "ui.targeting_reticle",
  "kind": "ui",
  "name": "Targeting Reticle",
  "aiManifest": {
    "summary": "A viewport-anchored targeting indicator that represents the current aim point.",
    "aliases": ["targeting reticle", "reticle", "crosshair", "aim indicator"],
    "actions": ["show aim", "track aim"],
    "targetRoles": ["player", "weapon", "camera"],
    "safeExamples": ["add targeting reticle AimReticle for Player near screen center"]
  },
  "compilerManifest": {
    "componentId": "ui.targeting_reticle",
    "extends": "ui.surface",
    "thingName": "AimReticle",
    "thingArchetype": "ui",
    "role": "targeting_feedback",
    "defaultConfig": {
      "surfaceName": "AimReticle",
      "lifecycle": "persistent",
      "trackingMode": "aim",
      "shape": "crosshair",
      "color": "rgba(255,255,255,0.92)",
      "width": 36,
      "height": 36
    },
    "inheritance": {
      "contracts": ["ui.targeting_reticle", "ui.targeting_feedback"],
      "defaultOwner": "component-manifest",
      "exposedOverrides": ["trackingMode"],
      "sealedDefaults": []
    },
    "provides": ["ui.targeting_reticle", "ui.targeting_feedback"],
    "requires": [],
    "binding": { "inputKind": "aim_feedback" },
    "relations": [{ "type": "indicates", "from": "componentThing", "to": "target" }],
    "placement": { "space": "ui", "preferredAnchor": "screen", "preferredDirection": "center" },
    "gdjsBridge": {
      "runtimeAdapters": ["targeting-reticle"],
      "adapterRoutes": {
        "targeting-reticle": {
          "owner": "runtime-adapter",
          "mechanism": "ui-targeting-reticle-adapter",
          "routeId": "ui-viewport-targeting-feedback",
          "routeOwner": "runtime-adapter",
          "routeMechanism": "ui-runtime-projection"
        }
      },
      "status": "implemented"
    }
  }
}
