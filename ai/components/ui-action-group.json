{
  "schemaVersion": 1,
  "id": "ui.action_group",
  "kind": "ui",
  "name": "Action Group",
  "aiManifest": {
    "summary": "A persistent group of related action entries that shares one screen region and arrangement.",
    "aliases": ["action group", "skill group", "skill bar", "ability bar", "action bar"],
    "actions": ["group actions", "trigger actions"],
    "targetRoles": ["player", "character"],
    "safeExamples": ["add action group Skills controls Player with actions skill one, skill two near screen bottom-right as cluster"]
  },
  "compilerManifest": {
    "componentId": "ui.action_group",
    "extends": "ui.group_surface",
    "thingName": "ActionGroup",
    "thingArchetype": "ui",
    "role": "action_group",
    "defaultConfig": {
      "surfaceName": "Actions",
      "lifecycle": "persistent",
      "actions": ["action"],
      "shape": "circle",
      "color": "rgba(42,92,180,0.78)",
      "width": 240,
      "height": 180,
      "buttonSize": 64
    },
    "inheritance": {
      "contracts": ["ui.action_group", "ui.group_layout", "input.action_collection"],
      "defaultOwner": "component-manifest",
      "exposedOverrides": ["actions"],
      "sealedDefaults": ["buttonSize"]
    },
    "provides": ["ui.action_group", "input.action_collection"],
    "requires": [],
    "binding": { "inputKind": "action_group" },
    "relations": [{ "type": "controls", "from": "componentThing", "to": "target" }],
    "placement": { "space": "ui", "preferredAnchor": "screen", "preferredDirection": "bottom-right" },
    "gdjsBridge": {
      "runtimeAdapters": ["action-group"],
      "adapterRoutes": {
        "action-group": {
          "owner": "runtime-adapter",
          "mechanism": "ui-action-group-adapter",
          "routeId": "ui-action-group-composition",
          "routeOwner": "runtime-adapter",
          "routeMechanism": "ui-runtime-composition"
        }
      },
      "status": "implemented"
    }
  }
}
