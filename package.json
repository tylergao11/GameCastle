{
  "name": "gamecastle",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/semantic-module",
    "packages/asset-engine",
    "packages/assembly-module"
  ],
  "scripts": {
    "build": "npm --prefix apps/web run build",
    "product:serve": "node apps/api/src/server.js",
    "model:semantic:start": "powershell -ExecutionPolicy Bypass -File scripts/models/start-semantic-llm.ps1",
    "model:semantic:smoke": "node scripts/shared/run-with-local-env.js scripts/models/smoke-semantic-llm.js",
    "asset:graph": "node packages/assets/src/inspect-asset-engine-langgraph.js",
    "check:asset-engine-execution": "node tests/run-project-gate.js asset-engine-execution",
    "debug:snake:live": "node scripts/shared/run-with-local-env.js scripts/semantic/debug-snake-real-llm.js",
    "runtime:prepare": "node scripts/gdevelop/prepare-gdjs-runtime.js && node scripts/gdevelop/prepare-gdevelop-codegen.js",
    "runtime:prepare:codegen": "node scripts/gdevelop/prepare-gdevelop-codegen.js",
    "capabilities:extract": "node scripts/gdevelop/extract-gdevelop-capability-universe.js",
    "capabilities:check": "node scripts/gdevelop/extract-gdevelop-capability-universe.js --check",
    "semantics:extract": "node scripts/gdevelop/extract-capability-semantic-index.js",
    "semantics:check": "node scripts/gdevelop/extract-capability-semantic-index.js --check",
    "event-grammar:extract": "node scripts/gdevelop/extract-gdevelop-event-grammar.js",
    "event-grammar:check": "node scripts/gdevelop/extract-gdevelop-event-grammar.js --check",
    "project-defaults:extract": "node scripts/gdevelop/extract-gdevelop-project-defaults.js",
    "project-defaults:check": "node scripts/gdevelop/extract-gdevelop-project-defaults.js --check",
    "spatial-truth:extract": "node scripts/gdevelop/extract-gdevelop-spatial-coordinate-truth.js",
    "spatial-truth:check": "node scripts/gdevelop/extract-gdevelop-spatial-coordinate-truth.js --check",
    "object-config:extract": "node scripts/gdevelop/extract-gdevelop-object-configuration-truth.js",
    "object-config:check": "node scripts/gdevelop/extract-gdevelop-object-configuration-truth.js --check",
    "check:semantic-loop": "node tests/run-project-gate.js semantic-loop",
    "check:product-loop": "node tests/run-project-gate.js product-loop",
    "check:semantic-engine": "node tests/run-project-gate.js semantic-engine",
    "check:semantic-module": "npm --workspace @gamecastle/semantic-module run test",
    "check:asset-module": "npm --workspace @gamecastle/asset-engine run check",
    "check:assembly-module": "npm --workspace @gamecastle/assembly-module run test",
    "check:modules": "node tests/run-project-gate.js modules",
    "check:project": "node tests/run-project-gate.js project",
    "check:llm-transport": "node tests/run-project-gate.js llm-transport",
    "check:provider": "node tests/run-project-gate.js provider",
    "check:network": "node tests/run-project-gate.js network"
  },
  "dependencies": {
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@supabase/storage-js": "2.110.5",
    "sharp": "0.34.5",
    "ws": "8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ws": "$ws"
  }
}
