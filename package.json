{
  "name": "gamecastle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm --prefix platform run build",
    "product:serve": "node server/product-engine-api.js",
    "asset:graph": "node ai/inspect-asset-engine-langgraph.js",
    "check:asset-engine-execution": "node tests/run-project-gate.js asset-engine-execution",
    "debug:snake:live": "node scripts/run-with-local-env.js scripts/debug-snake-real-llm.js",
    "runtime:prepare": "node scripts/prepare-gdjs-runtime.js && node scripts/prepare-gdevelop-codegen.js",
    "runtime:prepare:codegen": "node scripts/prepare-gdevelop-codegen.js",
    "truth:extract": "node scripts/extract-gdevelop-truth.js",
    "truth:check": "node scripts/extract-gdevelop-truth.js --check",
    "capabilities:extract": "node scripts/extract-gdevelop-capability-universe.js",
    "capabilities:check": "node scripts/extract-gdevelop-capability-universe.js --check",
    "semantics:extract": "node scripts/extract-capability-semantic-index.js",
    "semantics:check": "node scripts/extract-capability-semantic-index.js --check",
    "event-grammar:extract": "node scripts/extract-gdevelop-event-grammar.js",
    "event-grammar:check": "node scripts/extract-gdevelop-event-grammar.js --check",
    "project-defaults:extract": "node scripts/extract-gdevelop-project-defaults.js",
    "project-defaults:check": "node scripts/extract-gdevelop-project-defaults.js --check",
    "spatial-truth:extract": "node scripts/extract-gdevelop-spatial-coordinate-truth.js",
    "spatial-truth:check": "node scripts/extract-gdevelop-spatial-coordinate-truth.js --check",
    "object-config:extract": "node scripts/extract-gdevelop-object-configuration-truth.js",
    "object-config:check": "node scripts/extract-gdevelop-object-configuration-truth.js --check",
    "check:semantic-loop": "node tests/run-project-gate.js semantic-loop",
    "check:product-loop": "node tests/run-project-gate.js product-loop",
    "check:semantic-engine": "node tests/run-project-gate.js semantic-engine",
    "check:project": "node tests/run-project-gate.js project",
    "check:llm-transport": "node tests/run-project-gate.js llm-transport",
    "check:provider": "node tests/run-project-gate.js provider",
    "check:network": "node tests/run-project-gate.js network"
  },
  "dependencies": {
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@supabase/storage-js": "2.110.5",
    "sharp": "0.34.5",
    "ws": "8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ws": "$ws"
  }
}
