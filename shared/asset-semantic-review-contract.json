  "phasePolicy": {
    "master-candidate": {
      "hardGates": ["decodable-content", "semantic-margin", "composition-margin"],
      "rankingSignals": ["framing", "background-uniformity", "style-margin"],
      "principle": "Master images may contain a removable background; transparency is not required before deterministic derivation."
