{
  "schemaVersion": 3,
  "contractId": "gamecastle.semantic-asset-production",
  "owner": "AssetProductionPipeline",
  "truthSources": {
    "self": "shared/asset-production-pipeline-contract.json",
    "assetStyles": "shared/asset-style-dictionary.json",
    "semanticSource": "ai/game-semantic-source.js",
    "derivation": "ai/asset-derivation-pipeline.js"
  },
  "principles": [
    "GameSemanticSource owns semantic asset intent",
    "AssetLibrary may satisfy an exact requirement before generation",
    "ComfyUI creates one immutable master image and performs no asset processing",
    "AssetDerivationPipeline deterministically creates static assets and FrameSet revisions",
    "GDJS binds only accepted project-local revisions",
    "accepted new revisions enter the asynchronous publication outbox"
  ],
  "productionFamilies": {
    "character": { "defaultRecipeId": "character-sprite.v1" },
    "world-geometry": { "defaultRecipeId": "world-tile.v1" },
    "prop": { "defaultRecipeId": "prop-sprite.v1" },
    "background": { "defaultRecipeId": "scene-background.v1" },
    "ui": { "defaultRecipeId": "ui-element.v1" },
    "effect": { "defaultRecipeId": "effect-sprite.v1" },
    "character-animation": { "defaultRecipeId": "character-frame-set.v1" },
    "effect-animation": { "defaultRecipeId": "effect-frame-set.v1" }
  },
  "recipes": {
    "character-sprite.v1": { "artifactKind": "single-resource", "minimumPath": ["master-image", "deterministic-static", "accept"] },
    "world-tile.v1": { "artifactKind": "single-resource", "minimumPath": ["master-image", "deterministic-static", "accept"] },
    "prop-sprite.v1": { "artifactKind": "single-resource", "minimumPath": ["master-image", "deterministic-static", "accept"] },
    "scene-background.v1": { "artifactKind": "single-resource", "minimumPath": ["master-image", "deterministic-static", "accept"] },
    "ui-element.v1": { "artifactKind": "single-resource", "minimumPath": ["master-image", "deterministic-static", "accept"] },
    "effect-sprite.v1": { "artifactKind": "single-resource", "minimumPath": ["master-image", "deterministic-static", "accept"] },
    "character-frame-set.v1": { "artifactKind": "frame-set", "minimumPath": ["master-image", "deterministic-static", "deterministic-frame-set", "accept"] },
    "effect-frame-set.v1": { "artifactKind": "frame-set", "minimumPath": ["master-image", "deterministic-static", "deterministic-frame-set", "accept"] }
  },
  "artifacts": {
    "AssetProductionRequest": { "required": ["requestId", "projectId", "sourceHash", "requirements"] },
    "AssetProductionSetPlan": { "required": ["productionSetId", "sourceHash", "workItems", "dependencyGraph", "coveragePolicy", "contentHash"] },
    "AssetWorkItemPlan": { "required": ["workItemPlanId", "semanticId", "slotId", "targetVisualSlotId", "productionFamily", "recipeId", "artifactKind", "assetSpec", "stageSequence"] },
    "MasterImageRevision": { "required": ["revisionId", "path", "sha256", "width", "height", "providerReceipt"] },
    "WorkItemAcceptanceReceipt": { "required": ["workItemPlanId", "finalRevisionId", "targetVisualSlotId", "deterministicEvidenceIds", "styleId", "decision"] },
    "AssetProductionSetAcceptanceReceipt": { "required": ["productionSetId", "workItemAcceptanceReceiptIds", "requiredSlotCoverage", "acceptedRevisionByTargetVisualSlotId", "decision"] }
  }
}
