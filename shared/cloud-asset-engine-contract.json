{
  "schemaVersion": 2,
  "contractId": "gamecastle.cloud-asset-engine",
  "owner": "CloudAssetEngine",
  "purpose": "Provide all users with approved reusable game assets, template relationships, and local-first materialization plans.",
  "truthSources": {
    "cloudEngine": "shared/cloud-asset-engine-contract.json",
    "assetEngine": "shared/asset-engine-contract.json",
    "styleDictionary": "shared/asset-style-dictionary.json",
    "templateDictionary": "shared/asset-template-dictionary.json",
    "cloudDictionary": "shared/cloud-asset-dictionary.json",
    "localDerivation": "shared/local-derivation-contract.json",
    "providerGovernance": "shared/ai-provider-governance.json"
  },
  "truthModel": {
    "structuralRules": { "owner": "gamecastle.cloud-asset-engine", "source": "shared/cloud-asset-engine-contract.json" },
    "controlledCloudVocabulary": { "owner": "gamecastle.cloud-asset-dictionary", "source": "shared/cloud-asset-dictionary.json" },
    "visualGrammar": { "owner": "gamecastle.asset-style-dictionary", "source": "shared/asset-style-dictionary.json" },
    "templateDefinitions": { "owner": "gamecastle.asset-template-dictionary", "source": "shared/asset-template-dictionary.json" },
    "localOperations": { "owner": "gamecastle.local-derivation", "source": "shared/local-derivation-contract.json" },
    "publicAssetFacts": { "owner": "CloudRelationIndexPort", "authoritative": true },
    "blobBytesAndHashes": { "owner": "CloudBlobStorePort", "authoritative": true },
    "promotionWorkflow": { "owner": "CloudPromotionQueuePort", "authoritativeOnlyForWorkflow": true },
    "queryProjection": { "owner": "CloudProjectionPort", "authoritative": false, "rebuildFrom": ["CloudRelationIndexPort", "CloudBlobStorePort", "static dictionaries"] },
    "agentProposal": { "owner": "CloudAssetLibrarianAgent", "authoritative": false, "becomesFactOnlyAfter": "CloudGraphCommandPort.apply" }
  },
  "conflictRules": [
    "contract-owns-shape-and-invariants",
    "dictionary-owns-allowed-stable-ids",
    "relation-index-owns-published-facts-not-definitions",
    "projection-never-overrides-authoritative-facts",
    "unknown-or-conflicting-id-fails-closed",
    "template-and-style-values-are-references-not-copies"
  ],
  "controlledFields": {
    "semanticTags": { "owner": "gamecastle.cloud-asset-dictionary", "section": "semanticTags", "freeTextAllowed": false },
    "bundleKindId": { "owner": "gamecastle.cloud-asset-dictionary", "section": "bundleKinds", "freeTextAllowed": false },
    "qualityTierId": { "owner": "gamecastle.cloud-asset-dictionary", "section": "qualityTiers", "freeTextAllowed": false },
    "qualityFlags": { "owner": "gamecastle.cloud-asset-dictionary", "section": "qualityFlags", "freeTextAllowed": false },
    "provenanceTypeId": { "owner": "gamecastle.cloud-asset-dictionary", "section": "provenanceTypes", "freeTextAllowed": false },
    "licensePolicyId": { "owner": "gamecastle.cloud-asset-dictionary", "section": "licensePolicies", "freeTextAllowed": false },
    "styleId": { "owner": "gamecastle.asset-style-dictionary", "section": "styles", "freeTextAllowed": false },
    "templateId": { "owner": "gamecastle.asset-template-dictionary", "section": "templates", "freeTextAllowed": false },
    "kind": { "owner": "gamecastle.cloud-asset-engine", "section": "assetKinds", "freeTextAllowed": false }
  },
  "principles": [
    "shared-library-is-public-after-approval",
    "raw-user-input-never-enters-cloud",
    "cloud-finds-assets-local-runtime-makes-them-playable",
    "query-results-are-executable-candidates-not-graph-dumps",
    "local-deterministic-plan-before-model",
    "runtime-never-binds-remote-urls",
    "promotion-is-explicit-asynchronous-and-non-blocking",
    "immutable-blobs-and-revisions",
    "controlled-vocabulary-before-public-indexing",
    "template-definitions-come-from-template-dictionary",
    "no-legacy-schema-compatibility"
  ],
  "scopes": {
    "private-local": { "cloudAllowed": false, "public": false },
    "promotion-staging": { "cloudAllowed": true, "public": false },
    "cloud-shared": { "cloudAllowed": true, "public": true }
  },
  "planes": {
    "blobStore": { "owns": ["immutable bytes", "sha256", "media metadata"], "doesNotOwn": ["relationships", "runtime bindings"] },
    "relationIndex": { "owns": ["families", "revisions", "templates", "slots", "styles", "bundles", "typed relations"], "doesNotOwn": ["binary bytes", "project state"] },
    "projectionIndex": { "owns": ["exact lookup", "near lookup", "template kit lookup", "quality and usage ranking"], "rebuildable": true },
    "promotionQueue": { "owns": ["staging lifecycle", "retry", "receipts"], "blocksPlayerFlow": false }
  },
  "assetKinds": ["raster", "sprite-sheet", "audio", "font", "ui-template", "game-template", "asset-bundle"],
  "nodeKinds": {
    "AssetFamily": ["familyId", "kind", "semanticTags", "status"],
    "AssetRevision": ["revisionId", "familyId", "blobHash", "styleId", "provenanceTypeId", "licensePolicyId", "qualityTierId", "qualityFlags", "status"],
    "StyleProfile": ["styleId"],
    "Template": ["templateId", "templateKind", "version", "status"],
    "TemplateSlot": ["slotId", "templateId", "kind", "constraints"],
    "AssetBundle": ["bundleId", "bundleKindId", "status"]
  },
  "relationKinds": [
    { "id": "variantOf", "from": ["AssetRevision"], "to": ["AssetFamily"], "purpose": "group interchangeable revisions" },
    { "id": "derivedFrom", "from": ["AssetRevision"], "to": ["AssetRevision"], "purpose": "preserve deterministic or model lineage" },
    { "id": "belongsTo", "from": ["TemplateSlot"], "to": ["Template"], "purpose": "own a slot by one template" },
    { "id": "fillsSlot", "from": ["AssetFamily", "AssetRevision", "AssetBundle"], "to": ["TemplateSlot"], "purpose": "declare reusable template fit" },
    { "id": "usesStyle", "from": ["AssetRevision", "Template", "AssetBundle"], "to": ["StyleProfile"], "purpose": "bind visual grammar" },
    { "id": "contains", "from": ["AssetBundle"], "to": ["AssetFamily", "AssetRevision", "Template"], "purpose": "describe a reusable game asset kit" },
    { "id": "usedTogether", "from": ["AssetFamily", "AssetRevision"], "to": ["AssetFamily", "AssetRevision"], "purpose": "rank frequently co-used assets" }
  ],
  "flows": {
    "query": ["validate-query", "exact-lookup", "near-lookup", "template-kit-lookup", "build-local-plan", "rank-candidates", "return-candidate-set"],
    "materialize": ["authorize-public-read", "resolve-revision", "download-blob", "verify-hash", "write-project-local-revision", "return-materialization-receipt"],
    "promotion": ["receive-explicit-request", "validate-consent-and-scope", "validate-controlled-ids", "validate-acceptance-provenance-license", "dedupe-by-hash", "stage", "enrich-relations", "approve-or-reject", "publish-index", "return-promotion-receipt"],
    "maintenance": ["scan-integrity", "propose-family-and-relation-updates", "validate-proposal", "apply-command", "rebuild-projection", "write-audit-receipt"]
  },
  "artifacts": {
    "CloudAssetQuery": ["requestId", "assetSpec", "templateContext", "localCapabilities", "policy"],
    "CloudCandidateSet": ["requestId", "candidates", "templateKit", "summary"],
    "CloudCandidate": ["familyId", "revisionId", "matchKind", "score", "styleId", "rights", "qualityTierId", "qualityFlags", "localPlan"],
    "TemplateKitCandidate": ["templateId", "templateKind", "styleId", "slots"],
    "LocalMaterializationPlan": ["revisionId", "expectedHash", "operations", "requiresNewPixels", "estimatedCost"],
    "MaterializationRequest": ["requestId", "revisionId", "projectId", "targetScope"],
    "MaterializationReceipt": ["requestId", "revisionId", "projectLocalPath", "verifiedHash", "createdRevisionId"],
    "CloudPromotionRequest": ["requestId", "assetRevision", "acceptanceReceipt", "runtimeBindingReceipt", "shareConsent", "provenanceTypeId", "licensePolicyId", "qualityTierId", "qualityFlags"],
    "CloudPromotionReceipt": ["requestId", "decision", "stagingId", "familyId", "revisionId", "reasons"],
    "CloudGraphCommand": ["commandId", "actor", "operation", "targetIds", "payload", "reason"],
    "CloudGraphReceipt": ["commandId", "applied", "beforeHash", "afterHash", "issues"]
  },
  "queryMatchKinds": ["exact", "near-local-derivation", "template-kit", "none"],
  "promotionStates": ["requested", "validating", "staged", "enriching", "approved", "published", "rejected", "withdrawn"],
  "graphCommandOperations": ["addRelation", "setClassification", "markQuality", "createBundle", "withdrawRevision"],
  "agent": {
    "id": "CloudAssetLibrarianAgent",
    "purpose": "Maintain reusable families, template-slot relations, bundles, quality metadata, and integrity without blocking player creation.",
    "reads": ["promotion-staging metadata", "cloud-shared graph", "cloud asset dictionary", "style dictionary", "template dictionary", "aggregate usage"],
    "proposes": ["family assignment", "dictionary-owned semantic tags", "fillsSlot relation", "usedTogether relation", "dictionary-owned bundle membership", "dictionary-owned quality flags", "withdrawal recommendation"],
    "writesThrough": "CloudGraphCommandPort",
    "forbidden": ["read private-local bytes", "bind project runtime", "call image generation for a project", "publish without deterministic gates", "change immutable blobs", "auto-promote user input"]
  },
  "ports": [
    { "id": "CloudBlobStorePort", "methods": ["put", "get"], "owns": "immutable blob bytes only", "productionRequired": true },
    { "id": "CloudRelationIndexPort", "methods": ["load", "save"], "owns": "families, revisions, templates, slots, bundles, and relations", "productionRequired": true },
    { "id": "CloudPromotionQueuePort", "methods": ["load", "save"], "owns": "asynchronous promotion state and receipts", "productionRequired": true },
    { "id": "CloudAssetQueryPort", "methods": ["query"] },
    { "id": "CloudAssetMaterializePort", "methods": ["materialize"] },
    { "id": "CloudAssetPromotionPort", "methods": ["enqueuePromotion", "getPromotionStatus", "withdrawPromotion"] },
    { "id": "CloudGraphCommandPort", "methods": ["validate", "apply"] },
    { "id": "CloudProjectionPort", "methods": ["rebuild"], "owns": "rebuildable approved-revision query projection", "productionRequired": true },
    { "id": "CloudAccessPolicyPort", "methods": ["authorizeQuery", "authorizeMaterialize", "authorizePromotion"], "owns": "deployment-specific identity and public-read policy" }
  ],
  "testFixturePolicy": {
    "inMemoryPorts": "test-only",
    "forbidden": ["file-system cloud fallback", "fixture records as production evidence", "fixture records as shared-library truth"]
  },
  "hardGates": [
    "no-private-local-input-in-cloud",
    "no-publication-without-explicit-share-consent",
    "no-publication-without-acceptance-provenance-and-license",
    "no-simulated-or-test-assets-in-shared-library",
    "no-runtime-binding-to-remote-url",
    "no-model-call-when-local-plan-satisfies-spec",
    "no-agent-direct-storage-mutation",
    "no-free-form-public-classification-license-or-quality-id",
    "no-cloud-defined-template-or-style-token",
    "no-direct-filesystem-assumption-in-engine-core",
    "no-legacy-schema-alias-or-dual-write",
    "no-implicit-file-system-cloud-truth"
  ]
}
