    "goal.solve-reset": { "id": "goal.solve-reset", "revision": 1, "status": "approved-design", "category": "goal", "semanticRefs": ["semantic-dictionary#/playGoals/solve", "semantic-dictionary#/eventMeanings/PuzzleReset"], "provides": ["solution-state", "reset-transition"], "requires": ["interaction-state", "constraints"], "stateModel": ["unsolved", "solved", "reset"], "parameters": ["solutionRule", "resetPolicy"], "evidenceRequirements": ["valid solution and recoverable invalid state"] },
