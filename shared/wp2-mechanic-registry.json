{
  "schemaVersion": 1,
  "registryId": "gamecastle.wp2.mechanic-registry",
  "owner": "ProductMechanicRegistry",
  "status": "designed",
  "closedEnumeration": false,
  "purpose": "Provide stable product-mechanic capability IDs between creative semantics and low-level GDJS capabilities without defining a second meaning dictionary.",
  "truthBoundary": {
    "meaningOwner": "ai/semantic-mapping/semantic-feedback.json",
    "runtimeCapabilityOwner": "ai/gdevelop-truth/capability-universe.json",
    "semanticRoutingProjection": "ai/semantic-mapping/capability-semantic-index.json",
    "mechanicContractOwner": "this registry",
    "rule": "semanticRefs define why a mechanic exists; capability selectors define how approved implementations may be evidenced; neither side may copy the other owner's definitions."
  },
  "discoveryReferenceFormat": "mechanic-registry#/mechanics/<mechanic-id>",
  "executableReferenceFormat": "mechanic-registry#/approvedRevisions/<mechanic-id>/<revision>/<content-hash>",
  "revisionPolicy": {
    "mechanicsMapIsDiscoveryProjection": true,
    "discoveryEntriesAreNotExecutable": true,
    "approvedRevisionRecordsAreAppendOnly": true,
    "approvedReferencePins": ["mechanicId", "revision", "contentHash"],
    "currentAliasForbiddenInBuildArtifacts": true,
    "newRevisionNeverMutatesPriorRecord": true
  },
  "entryRequired": ["id", "revision", "status", "category", "semanticRefs", "provides", "requires", "stateModel", "parameters", "evidenceRequirements"],
  "categories": ["control", "motion", "interaction", "combat", "pressure", "goal", "economy", "progression", "lifecycle", "feedback", "space", "time"],
  "mechanics": {
