    "space.route": { "id": "space.route", "revision": 1, "status": "approved-design", "category": "space", "semanticRefs": ["semantic-dictionary#/gameplayRoles/route"], "provides": ["traversable-route"], "requires": ["regions"], "stateModel": ["open", "blocked", "completed"], "parameters": ["topology", "branching"], "evidenceRequirements": ["start-to-goal connectivity"] },
    "time.phase": { "id": "time.phase", "revision": 1, "status": "approved-design", "category": "time", "semanticRefs": ["semantic-dictionary#/gameplayRoles/phase_driver", "semantic-dictionary#/eventMeanings/PhaseTransitioned"], "provides": ["phase-clock"], "requires": ["phase-definition"], "stateModel": ["running", "transitioning", "complete"], "parameters": ["duration", "transitionPolicy"], "evidenceRequirements": ["ordered measurable phase transitions"] }
