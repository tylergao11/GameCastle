    "progression.upgrade": { "id": "progression.upgrade", "revision": 1, "status": "approved-design", "category": "progression", "semanticRefs": ["semantic-dictionary#/playGoals/grow", "semantic-dictionary#/eventMeanings/UpgradeApplied"], "provides": ["persistent-improvement"], "requires": ["upgrade-choice", "progress-resource"], "stateModel": ["locked", "available", "applied"], "parameters": ["choices", "stackPolicy"], "evidenceRequirements": ["choice changes future play"] },
