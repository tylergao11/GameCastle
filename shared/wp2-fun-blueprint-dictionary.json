          { "slotId": "pressure", "cardinality": "composed", "requiredMechanicRevisionRefs": [{ "mechanicId": "pressure.chase", "revision": 1, "contentHash": "37e8b7c7e916fa8f61c99e6f609735a94b95ee957561c1d5b66736b74f897db7" }, { "mechanicId": "pressure.wave", "revision": 1, "contentHash": "ba6f7082a139fda69e16d8a26a2201afe6111b22e20b2c9c84e377a419e95cd8" }], "allowedSubstitutionRevisionRefs": [] },
