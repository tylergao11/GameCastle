{
  "schemaVersion": 1,
  "dictionaryId": "gamecastle.wp2.fun-blueprint-dictionary",
  "owner": "FunBlueprintLibrary",
  "status": "designed",
  "closedFamilyEnumeration": false,
  "purpose": "Own human-reviewed reasons a composition should be fun while leaving implementation to mechanic modules and GDJS compilation.",
  "truthBoundary": {
    "owns": ["family discovery taxonomy", "core loops", "player decisions", "pressure structure", "progression structure", "reward pacing", "failure recovery", "capability-slot constraints", "forbidden combinations", "playtest assertions"],
    "doesNotOwn": ["semantic meanings", "mechanic implementations", "GDJS instructions", "final coordinates", "asset bytes", "complete game projects"],
    "semanticDictionary": "ai/semantic-mapping/semantic-feedback.json",
    "mechanicRegistry": "shared/wp2-mechanic-registry.json"
  },
  "familyReferenceFormat": "fun-blueprint-dictionary#/families/<family-id>",
  "blueprintReferenceFormat": "fun-blueprint-dictionary#/blueprints/<blueprint-id>/<revision>",
  "familyPolicy": {
    "multiFamilyMembership": true,
    "newFamilyRequiresHumanReview": true,
    "familyIdForbiddenAsGeneratorDispatch": true,
    "familiesAreDiscoveryFacetsNotSupportClaims": true,
    "aliasAndDeprecationRequireMigrationReceipt": true
  },
  "families": {
    "traversal_challenge": { "status": "seed", "playerValue": "Master movement, route reading, timing, and arrival.", "loopPatterns": ["observe route", "commit movement", "avoid or recover", "reach next landmark"], "antiDefinitions": ["side view alone", "platform behavior alone"] },
    "survival_pressure": { "status": "seed", "playerValue": "Stay viable while pressure grows or changes.", "loopPatterns": ["read pressure", "reposition", "reduce threat", "gain recovery or growth"], "antiDefinitions": ["enemies without shrinking options", "timer without pressure"] },
    "combat_mastery": { "status": "seed", "playerValue": "Improve attack, defense, positioning, and enemy-response skill.", "loopPatterns": ["identify threat", "choose target or defense", "execute", "read outcome"], "antiDefinitions": ["projectiles without meaningful target or risk"] },
    "timing_precision": { "status": "seed", "playerValue": "Succeed through rhythm, windows, reaction, and input precision.", "loopPatterns": ["anticipate cue", "act in window", "receive timing feedback", "maintain or recover chain"], "antiDefinitions": ["real-time execution without timing windows"] },
    "navigation_racing": { "status": "seed", "playerValue": "Optimize routes, speed, overtaking, or completion time.", "loopPatterns": ["read route", "manage speed", "choose line", "compare progress"], "antiDefinitions": ["vehicle graphics alone", "movement without comparative performance"] },
    "physics_play": { "status": "seed", "playerValue": "Predict and manipulate momentum, collision, balance, or physical chains.", "loopPatterns": ["predict", "apply force or placement", "observe simulation", "adjust"], "antiDefinitions": ["physics behavior used only for movement"] },
    "puzzle_inference": { "status": "seed", "playerValue": "Infer rules and construct a valid solution state.", "loopPatterns": ["inspect state", "form hypothesis", "manipulate", "validate or reset"], "antiDefinitions": ["locked door without inference", "single obvious interaction"] },
    "tactical_planning": { "status": "seed", "playerValue": "Win through position, action order, risk, and resource allocation.", "loopPatterns": ["assess", "plan", "commit actions", "resolve and adapt"], "antiDefinitions": ["multiple units without consequential choices"] },
    "economy_production": { "status": "seed", "playerValue": "Design production, conversion, building, and efficiency loops.", "loopPatterns": ["acquire input", "convert or build", "remove bottleneck", "expand capacity"], "antiDefinitions": ["currency counter without conversion decisions"] },
    "collection_progression": { "status": "seed", "playerValue": "Collect, unlock, combine, and grow toward long-term completion.", "loopPatterns": ["pursue reward", "collect", "choose growth", "unlock new pursuit"], "antiDefinitions": ["collectibles without future consequence"] },
    "social_competition_cooperation": { "status": "seed", "playerValue": "Create meaning through competition, cooperation, negotiation, or asymmetric roles.", "loopPatterns": ["observe players", "coordinate or contest", "resolve shared event", "adapt relationship"], "antiDefinitions": ["network transport alone", "leaderboard alone"] },
    "narrative_exploration_roleplay": { "status": "seed", "playerValue": "Discover, choose, relate, and express identity through a world.", "loopPatterns": ["explore", "discover context", "choose response", "observe consequence"], "antiDefinitions": ["dialogue text without choice or discovery"] }
  },
  "crosscutFacets": {
    "presentation": ["2d", "2_5d", "3d"],
    "view": ["side", "top-down", "isometric", "first-person", "third-person"],
    "timeModel": ["real-time", "turn-based", "pause-to-plan", "rhythm-synced"],
    "playerModel": ["single-player", "local-multiplayer", "online-multiplayer"],
    "socialRelation": ["solo", "cooperative", "competitive", "asymmetric", "mixed"],
    "worldStructure": ["fixed-level", "open-region", "room-graph", "procedural"],
    "sessionStructure": ["short-run", "level-based", "continuous-world", "persistent-management"],
    "controlSurface": ["keyboard-mouse", "gamepad", "touch", "single-input", "drag"],
    "failureModel": ["instant-retry", "checkpoint", "permanent-loss", "soft-failure"],
    "platform": ["web", "desktop", "mobile", "wechat-minigame"]
  },
  "blueprintContract": {
    "required": ["blueprintId", "revision", "status", "familyAffinities", "coreLoop", "playerDecisions", "pressureModel", "progressionModel", "rewardPacing", "failureRecovery", "mechanicSlots", "substitutionRules", "forbiddenCombinations", "allowedFacets", "parameterBounds", "playtestAssertions", "counterExamples", "humanReviewReceipt", "contentHash"],
    "statuses": ["draft", "approved", "deprecated"],
    "familyAffinityRequired": ["familyRef", "weight", "reason"],
    "mechanicSlotRequired": ["slotId", "cardinality", "requiredMechanicRevisionRefs", "allowedSubstitutionRevisionRefs"],
    "playtestAssertionRequired": ["assertionId", "measurement", "passRule", "failureOwner"],
    "forbiddenFields": ["targetPlan", "targetPlanText", "gdjsInstruction", "projectJson", "finalCoordinates", "assetPath"],
    "materialDifferenceRule": "Two compositions differ materially only when mechanic provider set, player decision structure, pressure model, or progression path differs; seed, topology, camera, art, or numeric reskin alone is insufficient.",
    "approvalGate": ["all mechanic refs resolve", "all semantic refs resolve", "positive composition evidence", "forbidden-combination rejection", "boundary parameter evidence", "failure and recovery evidence", "at least two materially distinct playable compositions"]
  },
