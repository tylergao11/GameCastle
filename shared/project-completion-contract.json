      "dependsOn": ["WP3", "WP4"],
      "scope": ["publishability gate", "immutable release", "release manifest", "share page", "withdraw and rollback", "asset and license verification"],
      "inputs": ["ProjectVersion", "ReleaseCandidate", "ValidationReport", "AssetManifest"],
      "outputs": ["PublishReceipt", "hosted release", "withdraw receipt"],
      "forbidden": ["publish with blocking debt", "serve mutable workspace", "remote asset URL in runtime", "publish without explicit user decision"],
      "completionEvidence": ["publish/withdraw/rollback integration", "content hash verification", "license rejection", "isolated hosted origin security test"]
    },
    {
      "id": "WP6", "name": "Identity and Project Cloud", "priority": "P1", "owner": "ProjectCloudService", "status": "designed",
      "dependsOn": ["WP3", "WP5"],
      "scope": ["account identity", "project ownership", "project sync", "release access policy", "conflict-safe version upload", "quota"],
      "inputs": ["authenticated actor", "ProjectVersion", "PublishReceipt"],
      "outputs": ["project cloud record", "sync receipt", "access decision", "quota receipt"],
      "forbidden": ["reuse CloudAssetEngine as personal project storage", "sync private raw assets without policy", "last-write-wins without version check"],
      "completionEvidence": ["two-user isolation", "offline/online reconciliation", "ownership transfer policy", "quota and authorization tests"]
    },
    {
