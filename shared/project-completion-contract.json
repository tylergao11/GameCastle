{
  "schemaVersion": 1,
  "contractId": "gamecastle.project-completion",
  "owner": "ProjectCompletionArchitecture",
  "purpose": "Turn the completed semantic, asset, and shared cloud engines into one fast, playable, iteratable, publishable, and operable GameCastle product without duplicating domain truth.",
  "truthSources": {
    "completion": "shared/project-completion-contract.json",
    "projectGraph": "ai/project-pipeline-graph.js",
    "pipelineState": "ai/pipeline-state.js",
    "runtimeContracts": "ai/contracts/schema.json",
    "assetEngine": "shared/asset-engine-contract.json",
    "cloudAssetEngine": "shared/cloud-asset-engine-contract.json",
    "styleDictionary": "shared/asset-style-dictionary.json",
    "templateDictionary": "shared/asset-template-dictionary.json",
    "assetProductionPipeline": "shared/asset-production-pipeline-contract.json",
    "cloudAssetDictionary": "shared/cloud-asset-dictionary.json",
    "providerGovernance": "shared/ai-provider-governance.json",
    "providerRuntime": "shared/provider-runtime-contract.json",
    "projectStore": "shared/project-store-contract.json",
    "wp2ProductModuleSystem": "shared/wp2-product-module-contract.json",
    "wp2TruthSources": "shared/wp2-truth-source-registry.json",
    "wp2Mechanics": "shared/wp2-mechanic-registry.json",
    "wp2TemplateSources": "shared/wp2-template-source-catalog.json",
    "wp2TemplateIr": "shared/wp2-template-ir-contract.json",
    "wp2FunBlueprints": "shared/wp2-fun-blueprint-dictionary.json",
    "wp2LegacyRegression": "shared/wp2-legacy-regression-suite.json",
    "creatorExperience": "shared/creator-experience-contract.json",
    "playableRuntime": "shared/playable-runtime-contract.json",
    "productModules": "ai/product-modules/schema.json",
    "gdevelopRuntimeTruth": "ai/gdevelop-truth/runtime-truth.json"
  },
  "completedFoundations": [
    { "id": "semantic-engine", "contract": "ai/contracts/schema.json", "status": "implemented" },
    { "id": "asset-engine", "contract": "shared/asset-engine-contract.json", "status": "partial-single-asset-core" },
    { "id": "cloud-asset-engine", "contract": "shared/cloud-asset-engine-contract.json", "status": "implemented-local-adapter" }
  ],
  "principles": [
    "one-idea-to-first-playable",
    "user-expression-is-free-system-metadata-is-closed",
    "optional-sketch-never-blocks-creation",
    "local-first-and-deterministic-before-model",
    "playable-progress-before-perfect-assets",
    "one-owner-one-truth-one-live-path",
    "project-weave-orchestrates-but-does-not-own-domain-logic",
    "every-success-produces-replayable-state-and-immutable-evidence",
    "smoke-coverage-is-not-product-completion",
    "no-legacy-schema-alias-or-dual-runtime"
  ],
  "productPromise": {
    "input": "One natural player idea, optionally with local uploads or sketches.",
    "firstOutcome": "A playable lightweight game appears without forcing the user through an engine-style setup flow.",
    "continuation": "The user can keep changing the same project in natural language with visible versions and rollback.",
    "finalOutcome": "A validated immutable release can be shared or published under explicit policy."
  },
  "milestones": [
    { "id": "local-creator-complete", "requires": ["WP0", "WP1", "WP2", "WP3", "WP4"], "meaning": "Natural idea to local playable iteration is product-complete." },
    { "id": "shareable-product-complete", "requires": ["local-creator-complete", "WP5", "WP6"], "meaning": "Projects can be safely persisted, published, shared, and rolled back." },
    { "id": "multiplayer-product-complete", "requires": ["shareable-product-complete", "WP7"], "meaning": "Selected multiplayer templates work under production room and reconnect boundaries." },
    { "id": "operable-product-complete", "requires": ["multiplayer-product-complete", "WP8"], "meaning": "The service is observable, secure, cost-governed, and migration-safe." }
  ],
  "projectLifecycle": {
    "states": ["empty", "understanding", "planning", "compiling", "resolving-assets", "assembling", "validating", "playable", "repairing", "iterating", "publishable", "published", "debt", "archived"],
    "terminalSuccess": ["playable", "publishable", "published"],
    "terminalRecovery": ["debt"],
    "transitions": [
      ["empty", "understanding"], ["understanding", "planning"], ["planning", "compiling"], ["compiling", "resolving-assets"],
      ["resolving-assets", "assembling"], ["assembling", "validating"], ["validating", "playable"], ["validating", "repairing"],
      ["repairing", "compiling"], ["repairing", "debt"], ["playable", "iterating"], ["iterating", "understanding"],
      ["playable", "publishable"], ["publishable", "published"], ["published", "iterating"], ["debt", "iterating"],
      ["playable", "archived"], ["published", "archived"]
    ]
  },
  "artifacts": {
    "ProjectRequest": { "owner": "PlatformIntentEntry", "required": ["requestId", "projectId", "mode", "naturalIntent"] },
    "ProjectRun": { "owner": "ProjectWeaveRuntime", "required": ["runId", "projectId", "state", "graphTrace", "startedAt"] },
    "BuildContract": { "owner": "IntentAgent", "source": "ai/contracts/schema.json" },
    "AssetWorld": { "owner": "AssetEngine", "source": "shared/asset-engine-contract.json" },
    "ProjectWorld": { "owner": "ProjectWorld", "required": ["worldVersion", "semanticHash", "modules", "scenes", "debts"] },
    "ValidationReport": { "owner": "RuntimeValidator", "required": ["checks", "pass", "ownerRoute", "blocksPublish"] },
    "PlaytestReport": { "owner": "SemanticPlaytestAgent", "required": ["measurements", "issues", "repairIntent", "pass"] },
    "PlayableRuntimeEvidence": { "owner": "RuntimeValidator", "source": "shared/playable-runtime-contract.json", "required": ["viewportMatrixReport", "assetProductionReport", "assetBindingReport", "tickPerformanceReport", "tickReplayReceipt", "browserPlaytestReport", "decision", "ownerRoute"] },
    "ProjectVersion": { "owner": "ProjectStore", "required": ["versionId", "projectId", "parentVersionId", "semanticHash", "releaseCandidateId", "createdAt"] },
    "ReleaseCandidate": { "owner": "ReleaseAssembler", "required": ["candidateId", "projectVersionId", "manifest", "validationReport", "assetManifest", "runtimeManifest"] },
    "PublishReceipt": { "owner": "Publisher", "required": ["releaseId", "projectId", "versionId", "decision", "publishedUrl", "contentHash"] },
    "OperationalEvent": { "owner": "TelemetryBoundary", "required": ["eventId", "projectId", "runId", "owner", "code", "timestamp"] }
  },
  "workPackages": [
    {
      "id": "WP0", "name": "Project Weave Live Orchestration", "priority": "P0", "owner": "ProjectWeaveRuntime", "status": "implemented",
      "dependsOn": ["semantic-engine", "asset-engine", "cloud-asset-engine"],
      "scope": ["one official LangGraph for every project owner", "checkpoint and resume", "owner-routed failure", "one create and continue path", "aggregate completion gate"],
      "inputs": ["ProjectRequest", "previous ProjectWorld", "previous AssetWorld"],
      "outputs": ["ProjectRun", "ProjectWorld", "AssetWorld", "ValidationReport", "PlaytestReport"],
      "forbidden": ["parallel shadow pipeline", "smoke-only node declared live", "UI parsing logs", "LLM reading raw target facts"],
      "completionEvidence": ["all Project Weave nodes use wired-langgraph status", "create and continue run through the same graph", "checkpoint resume test", "owner failure matrix", "npm run check:project"]
    },
    {
      "id": "WP1", "name": "Real Provider Runtime", "priority": "P0", "owner": "ProviderRuntime", "status": "implemented",
      "dependsOn": ["WP0"],
      "scope": ["creative and intent text providers", "image generation", "image edit", "vision review", "budget and privacy policy", "provider receipts"],
      "inputs": ["role request", "provider governance", "budget", "approved model transit data"],
      "outputs": ["typed provider result", "cost receipt", "provenance", "provider debt"],
      "forbidden": ["API key in project artifact", "silent simulated-to-real substitution", "model before local/cloud resolution", "unbounded retry"],
      "completionEvidence": ["provider contract tests", "simulated provider smoke per role", "timeout and budget tests", "simulated result cannot publish", "real-provider adapter is replaceable and fail-closed"]
    },
    {
      "id": "WP2", "name": "Gameplay Module and Template Coverage", "priority": "P0", "owner": "ProductModuleSystem", "status": "designed",
      "dependsOn": ["WP0"],
      "scope": ["licensed GDevelop/GDJS template intake", "deterministic TemplateIR normalization with per-node lineage and loss accounting", "open product mechanic registry", "open human-authored Fun Blueprint library", "TemplateIR-to-reusable-module foundry", "approved deterministic blueprint-constrained module composition", "macro spatial composition with PlacementResolver coordinate ownership", "two-phase module declaration and emission", "safe create and continue delta", "immutable module and blueprint promotion", "isolated legacy regression suite"],
      "legacyRegressionSuite": "shared/wp2-legacy-regression-suite.json",
      "inputs": ["licensed content-hashed GDevelop/GDJS template sources", "immutable approved Fun Blueprints", "immutable BuildContract gameplay requirement graph", "existing semantic dictionary and capability index", "approved revision-pinned product module manifests", "ProjectWorld continue truth"],
      "outputs": ["template source record", "TemplateIR", "Fun Blueprint selection", "module composition plan", "module declaration plan", "spatial composition plan", "compiled module plan", "module debt", "verified reusable module candidate and promotion receipt", "playable blueprint compositions", "historical regression fixtures"],
      "forbidden": ["fixed archetype count as template coverage", "closed Fun Blueprint family enumeration", "bare mechanic ids outside the canonical registry", "template intake without license provenance and content hash", "silent TemplateIR normalization loss", "GDJS tests binary promotion", "complete project copy or GDJS instructions inside Fun Blueprint", "new template requiring Planner or Compiler archetype dispatch", "second WP2 semantic dictionary", "LLM emitting module implementation or target plan", "online foundry", "final coordinates outside PlacementResolver", "legacy bridgePlan target execution", "one-off project patch outside module compiler", "remove or replace without guarded ownership and rollback"],
      "completionEvidence": ["WP2 foundation and machine contract checkers", "truth-source DAG cross-reference closure and reproducible drift checks", "two independent licensed template sources pass intake and deterministic TemplateIR replay", "unknown license and unsupported template structures fail closed", "TemplateIR-derived modules retain per-node source trace and prove reuse outside their source template", "blind unseen template reaches browser playtest without protected core changes", "approved open human-authored Fun Blueprint catalog with review receipts", "at least two mechanically or decisionally distinct browser-playable compositions per approved blueprint", "blueprint forbidden-combination, counterexample, boundary-parameter, failure and recovery tests", "isolated legacy regression suite remains green without contributing to coverage", "atomic remove and replace ownership cleanup tests", "online legacy target-plan bypass rejection", "offline foundry promotion gate", "independent tester and auditor reports"]
    },
    {
      "id": "WP3", "name": "Project Workspace and Version Lifecycle", "priority": "P0", "owner": "ProjectStore", "status": "implemented",
      "dependsOn": ["WP0"],
      "scope": ["multi-project local workspace", "autosave", "immutable versions", "rollback", "continue context", "optional Asset Studio"],
      "inputs": ["ProjectRun", "ProjectWorld", "AssetWorld", "release candidate"],
      "outputs": ["ProjectVersion", "project index", "rollback receipt", "active workspace"],
      "forbidden": ["single global output as multi-project truth", "project version without semantic hash", "forced sketch or setup wizard", "browser owning project files"],
      "completionEvidence": ["two-project isolation test", "crash recovery", "version rollback", "continue after restart", "UI project switch E2E"]
    },
    {
      "id": "WP4", "name": "Playable Iteration and Repair UX", "priority": "P0", "owner": "CreatorExperience", "status": "implemented",
      "dependsOn": ["WP0", "WP3"],
      "scope": ["one-screen idea entry", "visible project stages", "embedded playable preview", "natural iteration", "bounded automatic repair", "actionable debt"],
      "inputs": ["RunSnapshot", "playable release", "PlaytestReport", "owner route"],
      "outputs": ["user-visible result", "iteration request", "repair decision", "accepted playable version"],
      "forbidden": ["engine-form workflow", "raw owner diagnostics", "blocking optional asset step", "automatic destructive repair"],
      "completionEvidence": ["new user first-playable API/UI flow", "continue iteration API/UI flow", "cancel and rollback API/UI flow", "repair budget debt UX", "no-log-parsing UI contract"]
