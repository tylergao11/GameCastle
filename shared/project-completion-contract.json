      "dependsOn": ["WP2", "WP5", "WP6"],
      "scope": ["room lifecycle", "authoritative player slots", "reconnect", "sync strategy selection", "state persistence", "capacity limits"],
      "inputs": ["compiled network plan", "authenticated players", "runtime release"],
      "outputs": ["room receipt", "session state", "reconnect receipt", "multiplayer playtest report"],
      "forbidden": ["gameplay module implementing transport", "multiple realtime tick owners", "room state in browser truth", "multiplayer enabled without template capability"],
      "completionEvidence": ["two-client browser E2E", "disconnect/reconnect", "packet loss and ordering", "room cleanup", "authority and cheat-boundary tests"]
    },
    {
      "id": "WP8", "name": "Security, Observability, Cost, and Operations", "priority": "P2", "owner": "OperationsBoundary", "status": "designed",
      "dependsOn": ["WP0", "WP1", "WP5", "WP6", "WP7"],
      "scope": ["structured telemetry", "privacy and secret handling", "rate limit", "cost ledger", "backup and migration", "incident diagnostics", "SLO"],
      "inputs": ["OperationalEvent", "provider receipt", "publish event", "room event"],
      "outputs": ["health report", "cost report", "security decision", "migration receipt", "incident trace"],
      "forbidden": ["logs as domain truth", "secret in telemetry", "silent schema migration", "unbounded model or storage spend"],
      "completionEvidence": ["security test suite", "load and soak tests", "backup restore", "schema migration rehearsal", "cost limit enforcement", "operational dashboard smoke"]
    }
  ],
  "ports": [
    { "id": "ProjectWeavePort", "owner": "ProjectWeaveRuntime", "methods": ["create", "continue", "resume", "cancel"] },
    { "id": "ProjectStorePort", "owner": "ProjectStore", "methods": ["createProject", "saveVersion", "loadVersion", "rollback", "listProjects"] },
    { "id": "ProviderRuntimePort", "owner": "ProviderRuntime", "methods": ["invokeRole", "cancel", "health"] },
    { "id": "ReleasePort", "owner": "ReleaseAssembler", "methods": ["assemble", "verify", "commit"] },
    { "id": "PublishPort", "owner": "Publisher", "methods": ["publish", "withdraw", "resolveRelease"] },
    { "id": "ProjectCloudPort", "owner": "ProjectCloudService", "methods": ["authorize", "pushVersion", "pullProject", "resolveConflict"] },
    { "id": "MultiplayerPort", "owner": "MultiplayerRuntime", "methods": ["createRoom", "join", "leave", "reconnect", "closeRoom"] },
    { "id": "TelemetryPort", "owner": "OperationsBoundary", "methods": ["record", "measure", "health"] }
