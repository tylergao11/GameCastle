{
  "schemaVersion": 2,
  "contractId": "gamecastle.semantic-asset-engine",
  "sourceOfTruth": "GameSemanticSource assetIntents compiled to semantic-asset-requirements",
  "principles": [
    "asset meaning is decided only by LLM2 semantic source",
    "production family and recipe are pinned production truth",
    "all accepted assets are sourceHash-bound",
    "semantic cache keys require the complete requirement",
    "missing capability or failed validation is explicit and blocks final assembly"
  ],
  "graph": [
    "asset-intake",
    "local-input-archive",
    "model-authorize",
    "asset-production-plan",
    "asset-resolve",
    "asset-production-loop",
    "asset-finalize",
    "semantic-asset-cache"
  ],
  "inputs": ["semantic-asset-requirements", "local-input", "accepted semantic cache record"],
  "outputs": ["asset-manifest", "runtime-binding-manifest", "semantic-asset-world", "asset-production-report"],
  "forbidden": ["template selection", "cloud library fallback", "placeholder asset", "downstream gameplay decision", "silent retry after debt"]
}
