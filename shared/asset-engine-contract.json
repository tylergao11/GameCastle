{
  "schemaVersion": 2,
  "contractId": "gamecastle.semantic-asset-engine",
  "sourceOfTruth": "GameSemanticSource assetIntents compiled to semantic-asset-requirements",
  "defaults": {
    "imageResource": { "resourceKind": "image", "acceptedFormats": ["png"] }
  },
  "principles": [
    "asset meaning is decided only by LLM2 semantic source",
    "production family and recipe are pinned production truth",
    "all accepted assets are sourceHash-bound",
    "asset library keys require the complete reusable requirement",
    "the asset library is an optional cross-project acceleration source",
    "accepted local revisions complete creation before independent accumulation",
    "asset library failure never changes semantic intent or invalidates accepted local output",
    "missing capability or failed validation is explicit and blocks final assembly",
    "a FrameSetRevision reaches runtime only through its verified projection adapter"
  ],
  "graph": [
    "asset-intake",
    "local-input-archive",
    "asset-library-search",
    "model-authorize",
    "asset-production-plan",
    "asset-resolve",
    "asset-production",
    "asset-finalize",
    "asset-publication-enqueue"
  ],
  "stageDefinitions": {
    "asset-intake": [{ "module": "ai/asset-engine-langgraph.js", "exports": ["compileSpecs"] }],
    "local-input-archive": [{ "module": "ai/asset-engine-langgraph.js", "exports": ["archiveLocalInputs"] }],
    "asset-library-search": [{ "module": "ai/asset-library.js", "exports": ["create", "requirementFingerprint"] }],
    "model-authorize": [
      { "module": "ai/model-policy-gate.js", "exports": ["authorizeModelPorts"] },
      { "module": "ai/provider-runtime-adapters.js", "exports": ["createAssetProviderPorts"] }
    ],
    "asset-production-plan": [{ "module": "ai/asset-production-planner.js", "exports": ["compile"] }],
    "asset-resolve": [{ "module": "ai/asset-production-resolver.js", "exports": ["resolveProductionSet"] }],
    "asset-production": [{ "module": "ai/asset-production-pipeline.js", "exports": ["runProductionSet"] }],
    "asset-finalize": [
      { "module": "ai/asset-engine-langgraph.js", "exports": ["bindingManifest", "productionProjection"] },
      { "module": "ai/asset-world.js", "exports": ["buildAssetWorld"] }
    ],
    "asset-publication-enqueue": [
      { "module": "ai/asset-engine-langgraph.js", "exports": ["libraryRequirementForWorkItem"] },
      { "module": "ai/asset-publication-outbox.js", "exports": ["create"] }
    ]
  },
  "inputs": ["semantic-asset-requirements", "local-input", "optional asset-library accelerator port"],
  "outputs": ["asset-manifest", "runtime-binding-manifest", "semantic-asset-world", "asset-production-report", "asset-library-acceleration-report", "asset-publication-outbox-entries"],
  "forbidden": ["template selection", "unverified library reuse", "placeholder asset", "downstream gameplay decision", "silent retry after debt", "parallel asset cache"]
}
