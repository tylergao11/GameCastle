{
  "schemaVersion": 1,
  "dictionaryId": "gamecastle.cloud-asset-dictionary",
  "owner": "CloudAssetDictionary",
  "purpose": "Provide closed, stable identifiers for public cloud asset classification, quality, provenance, bundles, and reuse rights.",
  "semanticTags": {
    "role.hero": { "category": "role", "label": "Hero" },
    "role.enemy": { "category": "role", "label": "Enemy" },
    "role.npc": { "category": "role", "label": "NPC" },
    "scene.background": { "category": "scene", "label": "Background" },
    "scene.platform": { "category": "scene", "label": "Platform" },
    "object.prop": { "category": "object", "label": "Prop" },
    "object.collectible": { "category": "object", "label": "Collectible" },
    "ui.hud": { "category": "ui", "label": "HUD" },
    "ui.control": { "category": "ui", "label": "Control" },
    "effect.visual": { "category": "effect", "label": "Visual effect" },
    "audio.music": { "category": "audio", "label": "Music" },
    "audio.sfx": { "category": "audio", "label": "Sound effect" },
    "font.display": { "category": "font", "label": "Display font" }
  },
  "inputTerms": {
    "hero": "role.hero",
    "player": "role.hero",
    "enemy": "role.enemy",
    "monster": "role.enemy",
    "npc": "role.npc",
    "background": "scene.background",
    "platform": "scene.platform",
    "prop": "object.prop",
    "collectible": "object.collectible",
    "hud": "ui.hud",
    "button": "ui.control",
    "control": "ui.control",
    "effect": "effect.visual",
    "music": "audio.music",
    "sfx": "audio.sfx",
    "font": "font.display"
  },
  "bundleKinds": {
    "bundle.template-kit": { "purpose": "Assets that jointly satisfy declared template slots" },
    "bundle.style-set": { "purpose": "Assets sharing one style grammar" },
    "bundle.animation-set": { "purpose": "Frames or states belonging to one playable subject" }
  },
  "qualityTiers": {
    "quality.unrated": { "publicQueryAllowed": false, "rank": 0 },
    "quality.accepted": { "publicQueryAllowed": true, "rank": 10 },
    "quality.preferred": { "publicQueryAllowed": true, "rank": 20 },
    "quality.restricted": { "publicQueryAllowed": false, "rank": -10 }
  },
  "qualityFlags": {
    "quality.flag.low-resolution": { "blocksPromotion": false },
    "quality.flag.duplicate": { "blocksPromotion": false },
    "quality.flag.license-risk": { "blocksPromotion": true },
    "quality.flag.integrity-failure": { "blocksPromotion": true }
  },
  "provenanceTypes": {
    "provenance.user-final": { "publicPromotionAllowed": true, "requiresShareConsent": true },
    "provenance.model-assisted-final": { "publicPromotionAllowed": true, "requiresShareConsent": true },
    "provenance.deterministic-derived": { "publicPromotionAllowed": true, "requiresParentRevision": true },
    "provenance.system-template": { "publicPromotionAllowed": true, "requiresShareConsent": false },
    "provenance.simulated": { "publicPromotionAllowed": false },
    "provenance.unknown": { "publicPromotionAllowed": false }
  },
  "licensePolicies": {
    "license.creator-share": { "reuseAllowed": true, "derivativeAllowed": true, "redistributeInGameAllowed": true, "publicPromotionAllowed": true, "attributionRequired": false },
    "license.system-owned": { "reuseAllowed": true, "derivativeAllowed": true, "redistributeInGameAllowed": true, "publicPromotionAllowed": true, "attributionRequired": false },
    "license.third-party-attribution": { "reuseAllowed": true, "derivativeAllowed": true, "redistributeInGameAllowed": true, "publicPromotionAllowed": true, "attributionRequired": true },
    "license.private-owned": { "reuseAllowed": false, "derivativeAllowed": false, "redistributeInGameAllowed": false, "publicPromotionAllowed": false, "attributionRequired": false },
    "license.simulation-only": { "reuseAllowed": false, "derivativeAllowed": false, "redistributeInGameAllowed": false, "publicPromotionAllowed": false, "attributionRequired": false },
    "license.unknown": { "reuseAllowed": false, "derivativeAllowed": false, "redistributeInGameAllowed": false, "publicPromotionAllowed": false, "attributionRequired": false }
  },
  "governance": {
    "valuesAreClosed": true,
    "unknownIdsFailClosed": true,
    "newIdsRequireDictionaryRevision": true,
    "runtimeAliasesForbidden": true,
    "agentMayProposeExistingIdsOnly": true,
    "styleIdsOwnedBy": "gamecastle.asset-style-dictionary",
    "templateIdsOwnedBy": "gamecastle.asset-template-dictionary",
    "assetKindsOwnedBy": "gamecastle.cloud-asset-engine"
  }
}
