{
  "schemaVersion": 1,
  "contractId": "gamecastle.wp2.template-ir",
  "owner": "TemplateNormalizer",
  "status": "designed",
  "purpose": "Normalize GDevelop projects into deterministic structural evidence without copying editor caches, private data, or unlicensed distributable assets.",
  "input": "TemplateSourceRecord plus content snapshot plus GDevelop runtime truth",
  "required": ["templateIrId", "sourceRef", "sourceSchemaVersion", "normalizerVersion", "scenes", "objects", "behaviors", "variables", "eventGraph", "externalEvents", "resources", "animationGraphs", "extensionRequirements", "entryPoints", "sourceSpans", "lineage", "lossAccounting", "unknownFields", "diagnostics", "normalizationHash"],
  "sourceRefRequired": ["sourceId", "upstreamRevision", "contentHash", "licenseDecision"],
  "nodeKinds": ["scene", "object", "behavior", "variable", "event", "condition", "action", "expression", "external-event", "resource", "animation", "animation-frame", "extension-requirement", "entry-point"],
  "nodeRequired": ["nodeId", "kind", "sourceRefs", "scope", "order", "properties"],
  "stableNodeIdRule": "nodeId is derived from source identity plus structural source path, never array position alone or local absolute path.",
  "eventGraph": {
    "required": ["nodes", "edges", "groups", "orderConstraints", "triggerSemantics", "stateReads", "stateWrites"],
    "edgeKinds": ["contains", "precedes", "triggers", "reads", "writes", "creates", "deletes", "calls", "depends-on", "guards"],
    "preserveEventOrder": true,
    "silentDropForbidden": true
  },
  "animationGraph": {
    "required": ["ownerObjectId", "states", "transitions", "frameRefs", "timing", "loopPolicy", "sourceSpans"],
    "meaningPolicy": "Animation state and transition meaning may become mechanic evidence; source image bytes remain Asset Intake owned.",
    "defaultStateNames": ["idle", "move", "run", "jump", "fall", "attack", "hurt", "defeat", "interact"],
    "unknownStatePolicy": "preserve-name-and-route-to-semantic-review"
  },
  "resourceProjection": {
    "metadataOnlyByDefault": true,
    "required": ["resourceId", "kind", "sourcePath", "contentHash", "origin", "licenseDecision", "redistributionAllowed"],
    "bytesOwner": "AssetEngine",
    "unknownLicenseDecision": "structure-only"
  },
  "lineage": {
    "ownedByTemplateIR": ["sourceToIr", "sourceNodeDisposition"],
    "futureLineageForbidden": ["irToCandidate", "candidateToModule"],
    "appendOnlyProjectionOwner": "ModuleLineageProjection",
    "rule": "Immutable TemplateIR records only source-to-IR lineage. ModuleCandidateReceipt later records IR-to-candidate; ModulePromotionReceipt records candidate-to-module; an append-only projection provides bidirectional queries without rewriting prior artifacts."
  },
  "lossAccounting": {
    "required": ["consumedSourceNodes", "preservedUnknownNodes", "ignoredSourceNodes", "blockingSourceNodes"],
    "silentLossAllowed": false,
    "ignoredNodeRequired": ["sourceRef", "reason", "policyRule", "reviewReceipt"],
    "blockingRule": "Any executable or state-affecting unknown node blocks candidate promotion."
  },
  "unknownFieldPolicy": { "nonExecutable": "preserve-with-source-ref", "executableOrStateAffecting": "blocking-diagnostic", "drop": "forbidden" },
  "normalizationDiagnostics": ["UNSUPPORTED_PROJECT_SCHEMA", "UNSUPPORTED_EVENT_NODE", "UNKNOWN_EXTENSION", "MISSING_RESOURCE", "UNTRACEABLE_NODE", "CYCLIC_EXTERNAL_EVENT", "LICENSE_UNKNOWN", "PRIVATE_DATA_DETECTED"],
  "determinism": {
    "inputIdentity": ["source contentHash", "normalizerVersion", "runtime truth fingerprint"],
    "sameInputSameHash": true,
    "canonicalOrderingRequired": true,
    "absoluteLocalPathsForbiddenInHash": true
  },
  "forbidden": ["module selection", "playability claim", "final coordinate invention", "semantic meaning invention", "asset license inference", "target-plan emission"],
  "invariants": [
    "Every normalized node traces to one or more source spans.",
    "TemplateIR never predicts or is rewritten with future candidate or module lineage.",
    "Unsupported source structure produces blocking diagnostics.",
    "TemplateIR is structural evidence, not an approved module and not a complete project template for online use.",
    "Asset bytes never become reusable merely because their animation graph was normalized."
  ]
}
