plan-task(semanticId=seedTurn,goal="Create the snake turn seed",after=list())
plan-game(task=seedTurn,slot=gameRoot,semanticId=snakeProbe,intent=create)
plan-entity(task=seedTurn,slot=headEntity,semanticId=snakeHead,intent=create)
plan-entity(task=seedTurn,slot=foodEntity,semanticId=food,intent=create)
plan-entity(task=seedTurn,slot=stateEntity,semanticId=GameState,intent=create)
plan-entity(task=seedTurn,slot=scoreEntity,semanticId=scoreText,intent=create)
plan-member(task=seedTurn,slot=scoreMember,owner=GameState,semanticId=score,intent=create)
plan-member(task=seedTurn,slot=directionMember,owner=GameState,semanticId=direction,intent=create)
plan-member(task=seedTurn,slot=stepMember,owner=GameState,semanticId=step,intent=create)
plan-event(task=seedTurn,slot=turnEvent,semanticId=turn_up,intent=create,facets=list(metadata,conditions,actions))
plan-use(task=seedTurn,alias=upPressed,use=input.key.just-pressed)
plan-use(task=seedTurn,alias=setDirection,use=state.text.set)
game(slot=gameRoot,name="Snake Probe")
entity(slot=headEntity,roles=list(player,"snake-head"),kind=sprite,behaviors=list(topdown))
entity(slot=foodEntity,roles=list(food),kind=sprite,behaviors=list())
entity(slot=stateEntity,roles=list(state),kind=state,behaviors=list())
entity(slot=scoreEntity,roles=list(ui,score),kind=text,behaviors=list())
member(slot=scoreMember,roles=list(score),value=0,bindings=list())
member(slot=directionMember,roles=list("movement-direction"),value="right",bindings=list())
member(slot=stepMember,roles=list("grid-step"),value=32,bindings=list())
event(slot=turnEvent,kind=rule,locals=record())
when(slot=turnEvent,capability=upPressed,key="Up")
then(slot=turnEvent,capability=setDirection,target=directionMember,value="up")
