plan-task(semanticId=seedState,goal="Create the snake state seed",after=list())
plan-game(task=seedState,slot=gameRoot,semanticId=snakeProbe,intent=create)
plan-entity(task=seedState,slot=headEntity,semanticId=snakeHead,intent=create)
plan-entity(task=seedState,slot=foodEntity,semanticId=food,intent=create)
plan-entity(task=seedState,slot=stateEntity,semanticId=GameState,intent=create)
plan-entity(task=seedState,slot=scoreEntity,semanticId=scoreText,intent=create)
plan-member(task=seedState,slot=scoreMember,owner=GameState,semanticId=score,intent=create)
plan-member(task=seedState,slot=directionMember,owner=GameState,semanticId=direction,intent=create)
plan-member(task=seedState,slot=stepMember,owner=GameState,semanticId=step,intent=create)
game(slot=gameRoot,name="Snake Probe")
entity(slot=headEntity,roles=list(player,"snake-head"),kind=sprite,behaviors=list(topdown))
entity(slot=foodEntity,roles=list(food),kind=sprite,behaviors=list())
entity(slot=stateEntity,roles=list(state),kind=state,behaviors=list())
entity(slot=scoreEntity,roles=list(ui,score),kind=text,behaviors=list())
member(slot=scoreMember,roles=list(score),value=0,bindings=list())
member(slot=directionMember,roles=list("movement-direction"),value="right",bindings=list())
member(slot=stepMember,roles=list("grid-step"),value=32,bindings=list())
