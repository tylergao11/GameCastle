{
  "schemaVersion": 2,
  "benchmarkKind": "semantic-task-benchmark-contract",
  "benchmarkId": "snake-layered-v2",
  "requiredRuntimePhases": ["task-plan", "draft-write"],
  "requiredProtocolVersions": { "planner": "semantic-planner-prompt-v24", "executor": "semantic-executor-prompt-v30" },
  "dispatch": { "oneTaskPerRound": true, "completeCommand": "plan-complete" },
  "minimumCacheHitRate": 0.9,
  "hardTimeoutMs": 300000,
  "tasks": [
    {
      "id": "core-model",
      "seedFile": null,
      "task": "Create the core semantic model for Snake: the game identity, snake head sprite, food sprite, GameState state entity, and score text entity. Entity shells only — no members, no gameplay events.",
      "changeBudget": { "entities": { "exact": 4 }, "members": { "exact": 0 }, "components": { "exact": 0 }, "events": { "exact": 0 }, "assetIntents": { "exact": 0 }, "layoutIntents": { "exact": 0 } },
      "requiredEntities": [
        { "scope": "added", "semanticIdPattern": "^snake[-_. ]?head$", "kind": "sprite", "count": 1 },
        { "scope": "added", "semanticIdPattern": "^food$", "kind": "sprite", "count": 1 },
        { "scope": "added", "semanticIdPattern": "^game[-_. ]?state$", "kind": "state", "count": 1 },
        { "scope": "added", "semanticIdPattern": "^score[-_. ]?text$", "kind": "text", "count": 1 }
      ]
    },
    {
      "id": "state-fields",
      "seedFile": "tests/fixtures/semantic/semantic-snake-core-seed.dsl",
      "task": "Add three shared Snake state fields to GameState: score starts at 0, direction starts as right, and the grid step starts at 32. Keep existing entities and events unchanged.",
      "changeBudget": { "entities": { "exact": 0 }, "members": { "exact": 3 }, "components": { "exact": 0 }, "events": { "exact": 0 }, "assetIntents": { "exact": 0 }, "layoutIntents": { "exact": 0 } },
      "requiredMembers": [
        { "scope": "added", "entity": "GameState", "semanticIdPattern": "^score$", "value": 0, "count": 1 },
        { "scope": "added", "entity": "GameState", "semanticIdPattern": "^(direction|current[-_. ]?direction|movement[-_. ]?direction)$", "value": "right", "count": 1 },
        { "scope": "added", "entity": "GameState", "semanticIdPattern": "^(step|grid[-_. ]?step)$", "value": 32, "count": 1 }
      ]
    },
    {
      "id": "up-input",
      "seedFile": "tests/fixtures/semantic/semantic-snake-state-seed.dsl",
      "task": "Add one input rule that reacts when Up is newly pressed and changes GameState.direction to up.",
      "changeBudget": { "entities": { "exact": 0 }, "members": { "exact": 0 }, "components": { "exact": 0 }, "events": { "exact": 1 }, "assetIntents": { "exact": 0 }, "layoutIntents": { "exact": 0 } },
      "requiredEvents": [
        { "scope": "added", "count": 1, "conditionCount": 1, "actionCount": 1, "conditions": [{ "use": "input.key.just-pressed", "args": { "key": "Up" } }], "actions": [{ "use": "state.text.set", "args": { "target": "GameState.direction", "value": "up" } }] }
      ]
    },
    {
      "id": "timed-right-movement",
      "seedFile": "tests/fixtures/semantic/semantic-snake-turn-seed.dsl",
      "task": "Add one timed rightward grid-movement rule. It runs when the movement timer reaches 0.15 seconds and GameState.direction is right, then resets that timer and moves snakeHead along X by the current GameState.step value.",
      "changeBudget": { "entities": { "exact": 0 }, "members": { "exact": 0 }, "components": { "exact": 0 }, "events": { "exact": 1 }, "assetIntents": { "exact": 0 }, "layoutIntents": { "exact": 0 } },
      "requiredEvents": [
        { "scope": "added", "count": 1, "conditionCount": 2, "actionCount": 2, "conditions": [{ "use": "timer.elapsed", "args": { "operator": ">=", "seconds": 0.15 }, "capture": { "timer": "movementTimer" } }, { "use": "state.text.compare", "args": { "target": "GameState.direction", "operator": "=", "value": "right" } }], "actions": [{ "use": "timer.reset", "args": { "timer": { "$value": "movementTimer" } } }, { "use": "object.x.add", "args": { "target": "snakeHead", "value.use": "state.number", "value.target": "GameState.step" } }] }
      ]
    },
    {
      "id": "food-score-growth",
      "seedFile": "tests/fixtures/semantic/semantic-snake-turn-seed.dsl",
      "task": "Add pending growth state starting at 0 and one food-collection rule. When snakeHead collides with food, increase score and pending growth by 1, then relocate food to a grid position using the current grid step.",
      "changeBudget": { "entities": { "exact": 0 }, "members": { "exact": 1 }, "components": { "exact": 0 }, "events": { "exact": 1 }, "assetIntents": { "exact": 0 }, "layoutIntents": { "exact": 0 } },
      "requiredMembers": [{ "scope": "added", "entity": "GameState", "semanticIdPattern": "^(pending[-_. ]?)?growth$", "value": 0, "count": 1, "bind": "growth" }],
      "requiredEvents": [
        { "scope": "added", "count": 1, "conditionCount": 1, "actionCount": 3, "conditions": [{ "use": "object.collides", "args": { "first": "snakeHead", "second": "food" } }], "actions": [{ "use": "state.number.add", "args": { "target": "GameState.score", "value": 1 } }, { "use": "state.number.add", "args": { "target": { "$member": "growth" }, "value": 1 } }, { "use": "object.place.random-grid", "args": { "target": "food", "step.use": "state.number", "step.target": "GameState.step" } }] }
      ]
    },
    {
      "id": "loss-restart",
      "seedFile": "tests/fixtures/semantic/semantic-snake-turn-seed.dsl",
      "task": "On the existing board, add loss-and-restart: snakeBody entity, GameState.gameOver member (false), four boundary rules with object.x/y.compare setting GameState.gameOver, self-collision with snakeBody, and Space restart that clears gameOver, resets score, deletes body, and place.random-grid food. Keep existing GameState fields and entities unless this goal changes them.",
      "changeBudget": {
        "entities": { "minimum": 1, "maximum": 2 },
        "members": { "minimum": 1, "maximum": 3 },
        "components": { "exact": 0 },
        "events": { "minimum": 3, "maximum": 8 },
        "assetIntents": { "exact": 0 },
        "layoutIntents": { "exact": 0 }
      },
      "requiredEntities": [{ "scope": "added", "semanticIdPattern": "^snake[-_. ]?body$", "kind": "sprite", "count": 1, "bind": "body" }],
      "requiredMembers": [{ "scope": "added", "entity": "GameState", "semanticIdPattern": "^(is[-_. ]?)?game[-_. ]?over([A-Za-z0-9_-]*)$", "value": false, "count": 1, "bind": "gameOver" }],
      "requiredEvents": [
        { "scope": "added", "count": 1, "conditions": [{ "use": "object.collides", "args": { "first": "snakeHead", "second": { "$entity": "body" } } }], "actions": [{ "use": "state.boolean.set", "args": { "target": { "$member": "gameOver" }, "value": true } }] },
        { "scope": "added", "count": 1, "conditions": [{ "use": "input.key.just-pressed", "args": { "key": "Space" } }, { "use": "state.boolean.is", "args": { "target": { "$member": "gameOver" }, "value": true } }], "actions": [{ "use": "state.boolean.set", "args": { "target": { "$member": "gameOver" }, "value": false } }, { "use": "state.number.set", "args": { "target": "GameState.score", "value": 0 } }, { "use": "object.delete", "args": { "target": { "$entity": "body" } } }, { "use": "object.place.random-grid", "args": { "target": "food" } }], "bind": "restart" }
      ],
      "coverageOperations": [
        { "channel": "conditions", "use": "object.x.compare", "args": { "target": "snakeHead", "operator": "<" }, "minimum": 1, "sameEventActions": [{ "use": "state.boolean.set", "args": { "target": { "$member": "gameOver" }, "value": true } }] },
        { "channel": "conditions", "use": "object.x.compare", "args": { "target": "snakeHead", "operator": ">" }, "minimum": 1, "sameEventActions": [{ "use": "state.boolean.set", "args": { "target": { "$member": "gameOver" }, "value": true } }] },
        { "channel": "conditions", "use": "object.y.compare", "args": { "target": "snakeHead", "operator": "<" }, "minimum": 1, "sameEventActions": [{ "use": "state.boolean.set", "args": { "target": { "$member": "gameOver" }, "value": true } }] },
        { "channel": "conditions", "use": "object.y.compare", "args": { "target": "snakeHead", "operator": ">" }, "minimum": 1, "sameEventActions": [{ "use": "state.boolean.set", "args": { "target": { "$member": "gameOver" }, "value": true } }] }
      ],
      "forbiddenOperations": [
        { "channel": "actions", "use": "object.x.add" },
        { "channel": "actions", "use": "object.y.add" },
        { "channel": "actions", "use": "state.number.add", "args": { "target": "GameState.score" } }
      ],
      "lifecycleRules": [{ "eventBinding": "restart", "target": "food", "resetUse": "object.place.random-grid", "deleteUse": "object.delete", "recreateUse": "object.create" }]
    }
  ]
}
